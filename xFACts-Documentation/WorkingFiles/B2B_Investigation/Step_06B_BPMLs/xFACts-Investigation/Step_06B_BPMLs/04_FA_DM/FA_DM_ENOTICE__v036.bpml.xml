      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <choice name="Choice Start">
      <select>
        <case ref="GotFiles?" activity="GetDocsToSend"/>
      </select>

      <sequence name="GetDocsToSend">
        <operation name="Invoke Business Process Service">
          <participant name="InlineInvokeBusinessProcessService"/>
          <output message="InvokeBusinessProcessServiceTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
            <assign to="WFD_NAME">FA_CLIENTS_GET_DOCS</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
    <sequence name="OutSFTP">
      <operation name="SFTP Client Begin Session Service">
        <participant name="SFTPClientBeginSession"/>
        <output message="SFTPClientBeginSessionServiceTypeInputMessage">
          <assign to="." from="*"></assign>
          <assign to="PreferredAuthenticationMethod">password</assign>
          <assign to="ProfileId" from="//Result/Client[1]/PUT_DOCS_PROFILE_ID/text()"></assign>
          <assign to="SFTPClientAdapter">SFTPClientAdapter</assign>
        </output>
        <input message="inmsg">
          <assign to="." from="*"></assign>
        </input>
      </operation>

      <operation name="SFTP Client CD Service">
        <participant name="SFTPClientCd"/>
        <output message="SFTPClientCdServiceTypeInputMessage">
          <assign to="." from="*"></assign>
          <assign to="CdUp">YES</assign>
          <assign to="Directory" from="//Result/Client[1]/PUT_DOCS_LOC/text()"></assign>
        </output>
        <input message="inmsg">
          <assign to="." from="*"></assign>
        </input>
      </operation>

      <operation name="AssignService">
        <participant name="AssignService"/>
        <output message="outmsg">
          <assign to="currentdoc">1</assign>
          <assign to="noofdocs" from="//FSA_DocumentCount/text()"></assign>
        </output>
        <input message="inmsg">
          <assign to="." from="*"></assign>
        </input>
      </operation>

      <sequence name="FileLoop">
        <choice name="Choice Start">
          <select>
            <case ref="GetDocs?" activity="DropFile"/>
          </select>

          <sequence name="DropFile">
            <operation name="Release Service">
              <participant name="ReleaseService"/>
              <output message="outmsg">
                <assign to="TARGET">PrimaryDocument</assign>
              </output>
              <input message="inmsg">
              </input>
            </operation>

            <assign name="Assign" to="/ProcessData/PrimaryDocument" from="//*[ name() =  concat(&apos;FSA_Document&apos;,//currentdoc/text())]/@SCIObjectID"></assign>
            <operation name="SFTP Client PUT Service">
              <participant name="SFTPClientPut"/>
              <output message="SFTPClientPutServiceTypeInputMessage">
                <assign to="." from="*"></assign>
              </output>
              <input message="inmsg">
                <assign to="." from="*"></assign>
              </input>
            </operation>

            <assign name="Assign" to="currentdoc" from="currentdoc+1"></assign>
            <repeat name="Repeat" ref="FileLoop"/>

          </sequence>
        </choice>
      </sequence>
      <operation name="SFTP Client End Session Service">
        <participant name="SFTPClientEndSession"/>
        <output message="SFTPClientEndSessionServiceTypeInputMessage">
          <assign to="." from="*"></assign>
        </output>
        <input message="inmsg">
          <assign to="." from="*"></assign>
        </input>
      </operation>

    </sequence>
    <choice name="Choice Start">
      <select>
        <case ref="Email?" activity="SendEmail"/>
      </select>

      <sequence name="SendEmail">
        <operation name="AssignService">
          <participant name="AssignService"/>
          <output message="outmsg">
            <assign to="//Result/Client/EMAIL_XSLT">FA_ENOTICE_SUMMARY</assign>
            <assign to="//Result/Client/MAIL_TO">datahelp@frost-arnett.com,applications@frost-arnett.com</assign>
            <assign to="//Result/Client/CLIENT_NAME">Reg-F Letters</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="Release Service">
          <participant name="ReleaseService"/>
          <output message="outmsg">
            <assign to="TARGET">PrimaryDocument</assign>
          </output>
          <input message="inmsg">
          </input>
        </operation>

        <operation name="Lightweight JDBC Adapter">
          <participant name="AS2LightweightJDBCAdapter"/>
          <output message="LightweightJDBCAdapterTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
            <assign to="query_type">SELECT</assign>
            <assign to="result_name">EmailInfo</assign>
            <assign to="row_name">Values</assign>
            <assign to="sql">WITH CTE AS (        SELECT FILE_NAME,NOTICE_ID,   COUNT(DISTINCT NOTICE_NODE_ID) DIFFERENT_NOTICES,       MAX(NOTICE_NODE_ID) ROLLUP_NOTICE_ID       FROM Integration.ETL.tbl_ENOTICE_TO_REVSPRING_VALDN       GROUP BY FILE_NAME,NOTICE_ID      ),  CTE2 AS (        SELECT DISTINCT CAST(INSERT_DATE AS DATE)INSERT_DATE,   MAX(FILE_NAME) FILE_NAME,       NOTICE_NODE_ID,NOTICE_ID      FROM Integration.ETL.tbl_ENOTICE_TO_REVSPRING_VALDN          GROUP BY NOTICE_ID, CAST(INSERT_DATE AS DATE),NOTICE_NODE_ID,SENT      ),   CTE3 AS (      SELECT DISTINCT CAST(A.INSERT_DATE AS DATE) INSERT_DATE,     A.FILE_NAME,   COUNT(DISTINCT A.ACCNT_ID) ACCNT_COUNT_ID        FROM Integration.ETL.tbl_ENOTICE_TO_REVSPRING_VALDN A        INNER JOIN CTE2 B ON A.FILE_NAME = B.FILE_NAME        GROUP BY A.FILE_NAME,CAST(A.INSERT_DATE AS DATE)       ),   CTE4 AS (       SELECT FILE_NAME,COUNT(*) FILTERED_OUT       FROM ( SELECT FILE_NAME, COUNT(DISTINCT NOTICE_NODE_ID) UNDER_10     FROM Integration.ETL.tbl_ENOTICE_TO_REVSPRING_VALDN      GROUP BY FILE_NAME,NOTICE_NODE_ID      HAVING (SUM(ROLLUP_UPD_SERV_BAL_DUE) &lt;= 0 OR SUM(ROLLUP_UPD_SERV_BAL_DUE) IS NULL) ) A        GROUP BY FILE_NAME       ),  CTE5 AS (     SELECT FILE_NAME,COUNT(*) VALID_AND_UNDER_10      FROM (  SELECT FILE_NAME, COUNT(DISTINCT NOTICE_NODE_ID) UNDER_10        FROM Integration.ETL.tbl_ENOTICE_TO_REVSPRING_VALDN       GROUP BY FILE_NAME,NOTICE_NODE_ID       HAVING (SUM(ROLLUP_UPD_SERV_BAL_DUE) &gt; 0 AND     SUM(ROLLUP_UPD_SERV_BAL_DUE) IS NOT NULL)   AND SUM(DM_ACCNT_BALANCE) &lt; 10  ) A GROUP BY FILE_NAME),  CTE6 AS (     SELECT COUNT(DISTINCT NOTICE_ID) SMS_COUNT,FILE_NAME FROM Integration.ETL.tbl_ENOTICE_TO_REVSPRING_VALDN A     WHERE DOC_CODE_AFTER IN (SELECT TEXTING_CODE FROM Integration.ETL.tbl_ENOTICE_TO_REVSPRING_LTR_TXT_CROSSWALK)     GROUP BY FILE_NAME     ),  CTE7 AS (       SELECT DISTINCT CAST(INSERT_DATE AS DATE)INSERT_DATE,   MAX(FILE_NAME) FILE_NAME,     NOTICE_NODE_ID,NOTICE_ID    FROM Integration.ETL.tbl_ENOTICE_TO_REVSPRING_VALDN       WHERE SENT = 1     GROUP BY NOTICE_ID, CAST(INSERT_DATE AS DATE),NOTICE_NODE_ID,SENT    )  SELECT A.FILE_NAME,     MAX(B.INSERT_DATE) INSERT_DATE,       COUNT(DISTINCT A.NOTICE_ID) NOTICE_RECEIVED,    MAX(A.ROLLUP_NOTICE_ID)   GENERATED_NOTICES,    ISNULL(MAX(FILTERED_OUT),0) FILTERED_OUT,     COUNT(DISTINCT F.NOTICE_NODE_ID) NOTICE_SENT_OUT,    MAX( B.ACCNT_COUNT_ID) ACCNT_COUNT,      FORMAT(CAST((((MAX(ROLLUP_NOTICE_ID) - COUNT(DISTINCT A.NOTICE_ID) )*100)/(COUNT(DISTINCT A.NOTICE_ID))*100)*.0001 AS FLOAT),&apos;P&apos;) LETTER_INCREASE,  CAST(AVG(CAST(DIFFERENT_NOTICES as DECIMAL(10,2))) AS DECIMAL(5, 2)) AVG_CNSMR_ROLLUP,     MIN(DIFFERENT_NOTICES) LOWEST_ROLLUP_AMOUNT,     MAX(DIFFERENT_NOTICES) HIGHEST_ROLLUP_AMOUNT,    MAX(SMS_COUNT) TEXTING_COUNT,   FORMAT(CAST((CAST(MAX(SMS_COUNT) AS FLOAT)/CAST((COUNT(DISTINCT A.NOTICE_ID)) AS FLOAT)*100)*.01 AS FLOAT),&apos;P&apos;) TEXTING_PERCENTAGE   FROM CTE A   INNER JOIN CTE3 B ON A.FILE_NAME = B.FILE_NAME     LEFT JOIN CTE4 C ON A.FILE_NAME = C.FILE_NAME   LEFT JOIN CTE5 D ON A.FILE_NAME = D.FILE_NAME    LEFT JOIN CTE6 E ON A.FILE_NAME = E.FILE_NAME   LEFT JOIN CTE7 F ON A.FILE_NAME = F.FILE_NAME   GROUP BY A.FILE_NAME  ORDER BY INSERT_DATE,FILE_NAME</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
            <assign to="." from="DocToDOM(PrimaryDocument)"></assign>
          </input>
        </operation>

        <assign name="Assign" to="." from="DocToDOM(PrimaryDocument)"></assign>
        <operation name="Invoke Business Process Service">
          <participant name="InlineInvokeBusinessProcessService"/>
          <output message="InvokeBusinessProcessServiceTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
            <assign to="WFD_NAME">FA_CLIENTS_EMAIL</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="Lightweight JDBC Adapter">
          <participant name="AS2LightweightJDBCAdapter"/>
          <output message="LightweightJDBCAdapterTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
            <assign to="query_type">PROCEDURE</assign>
            <assign to="result_name">Cancel</assign>
            <assign to="row_name">Notices</assign>
            <assign to="sql">EXEC faint.USP_ENOTICE_DM_CANCELLATION</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
            <assign to="." from="DocToDOM(PrimaryDocument)"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
    <onFault>
      <sequence name="OnErrorEmail">
        <operation name="Lightweight JDBC Adapter">
          <participant name="AS2LightweightJDBCAdapter"/>
          <output message="LightweightJDBCAdapterTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="param1" from="if(boolean(contains(//Settings/Values/DATABASE_SERVER/text(),&apos;PROD&apos;)),235,10221)"></assign>
            <assign to="param2">8</assign>
            <assign to="param3" from="number(//thisProcessInstance/INVOKE_ID_LIST/text())"></assign>
            <assign to="param4">Reg-F Letters</assign>
            <assign to="paramtype1">Integer</assign>
            <assign to="paramtype2">Integer</assign>
            <assign to="paramtype3">Integer</assign>
            <assign to="paramtype4">String</assign>
            <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
            <assign to="query_type">INSERT</assign>
            <assign to="result_name">Result</assign>
            <assign to="row_name">Client</assign>
            <assign to="sql">INSERT INTO ETL.tbl_B2B_CLIENTS_TICKETS VALUES(NULL,?,?,?,?,NULL,&apos;MAP ERROR&apos;,GETDATE(),NULL,NULL)</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <assign name="Assign" to="//Result/Client/CLIENT_NAME">FAIL - Reg-F Letters</assign>
        <operation name="Invoke Business Process Service">
          <participant name="InvokeBusinessProcessService"/>
          <output message="InvokeBusinessProcessServiceTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="INVOKE_MODE">ASYNC</assign>
            <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
            <assign to="WFD_NAME">FA_CLIENTS_EMAIL</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </onFault>
  </sequence>
</process>

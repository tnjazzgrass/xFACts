<!-- 
Extract a list of users in the named group (notifications) from
the database and send an email notification to each of those users.

@author Corey Sanders
@version 1.0
 -->
<process name="AlertNotification">
  <rule name="has more users">
    <condition>number(//index/text()) &lt; number(//rowCount/text())</condition>
  </rule>
  <rule name="isAdmin">
    <condition>
      username = 'admin'
    </condition> 
  </rule>
  
<sequence>
  <sequence>
    <operation name="Get mailfrom">
      <participant name="UserService"/>
      <output message="UserServiceTypeInputMessage">
      	<assign to="MethodName">getEmail</assign>
      	<assign to="UserName">admin</assign>
      	<assign to="." from="*"/>
      </output>
      <input message="inmsg">
	<assign to="mailfrom" from="//UserService/getEmail/text()"/>
      </input>
    </operation>
    <onFault>
      <sequence>
        <assign to="mailBody" from="PrimaryDocument/@SCIObjectID"></assign>	
	<assign to="mailfrom" from="'datahelp@frost-arnett.com'"/>
      </sequence>
    </onFault>
  </sequence> 

  <!-- need to backup primary document so we don't lose it when JDBC call is run. -->
  <assign to="mailBody" from="PrimaryDocument/@SCIObjectID"/>  
    
  <operation name="Get Usernames">
    <participant name="LightweightJDBCAdapterQuery"/>
    <output message="LightweightJDBCAdapterTypeInputMessage">
    <!-- for some reason, need to hardcode the poolname here... -->
      <assign to="pool">mssqlPool</assign>
      <assign to="query_type">SELECT</assign>
      <assign to="result_name">result</assign>
      <assign to="row_name">row</assign>
      <assign to="sql">select YFS_USER.LOGINID from YFS_USER, YFS_USER_GROUP, YFS_USER_GROUP_LIST where USERGROUP_ID = ? and YFS_USER_GROUP.USERGROUP_KEY = YFS_USER_GROUP_LIST.USERGROUP_KEY and YFS_USER.USER_KEY = YFS_USER_GROUP_LIST.USER_KEY</assign>
      <assign to="paramtype1">String</assign>
      <assign to="param1">notifications</assign>
      <assign to="." from="*"/>
    </output>
    <input message="inmsg">
      <assign to="." from="*"/>
    </input>
  </operation>
    
  <operation name="Promote to ProcessData">
    <participant name="XMLEncoder"/>
    <output message="XMLEncoderTypeInputMessage">
      <assign to="map_name">NOT_USED</assign>
      <assign to="mode">xml_to_process_data</assign>
      <assign to="output_to_process_data">YES</assign>
      <assign to="root_element">result</assign>
      <assign to="." from="*"/>
    </output>
    <input message="inmsg">
      <assign to="." from="*"/>
    </input>
  </operation>

  <!-- restore the original primary document from backup -->
  <assign to="PrimaryDocument" from="mailBody/@SCIObjectID" append="false"/>  

  <!-- setup the loop variables -->
  <assign to="index">0</assign>
  <assign to="rowCount" from="count(//result/row)"/>
    
  <!-- for each user in the group, get the user's email address -->
  <choice name="for each user">
    <select>
      <case ref="has more users" activity="append Email Address"/>
    </select>
  
    <sequence name="append Email Address">
      <assign to="username" from="//result/row[number(//index/text())+1]/LOGINID/text()"/>

      <choice name="if is admin">
	<select>
	  <case ref="isAdmin" activity="get admin email"/>
	  <case ref="isAdmin" negative="true" activity="get other emails"/>
	</select>
			    
	<sequence name="get admin email">
	  <assign to="mailto" from="//mailfrom/text()" />
	</sequence>
			    
	<sequence name="get other emails">
	  <operation name="get mailto">
	    <participant name="UserService"/>
	    <output message="UserServiceTypeInputMessage">
	      <assign to="MethodName">getEmail</assign>
	      <assign to="UserName" from="//username/text()"/>
	      <assign to="." from="*"/>
	    </output>
	    <input message="inmsg">
	      <assign to="mailto" from="//UserService/getEmail/text()"/>
	    </input>
	  </operation>
			    	
	  <onFault>
	    <sequence name="handle get mail to error">
	      <operation>
		<participant name="XMLEncoder"/>
		<output message="Xout">
		  <assign to="mode">process_data_to_document</assign>
		  <assign to="xPath">/ProcessData/*[starts-with(local-name(.),'Prev_NotSuccess_Adv_Status')]</assign>
		  <assign to="root_element">ErrorMessage</assign>
		  <assign to="." from="*"/>
		</output>
		<input message="Xin">
		  <assign to="." from="*"/>
		</input>
	      </operation>
	    </sequence>
	  </onFault>
        </sequence>
      </choice>
        
      <!-- putting the SMTPSend here is easier to implement than building
           a CC list and sending the message later. If performance becomes
           a problem, however, we can go back and tweak this to be more
           efficient.
      -->
      <sequence name="Submit notification">
        <operation name="SMTP Send">
          <participant name="SMTP_SEND_ADAPTER"/>
          <output message="SMTP_SEND_ADAPTERInputMessage">
            <assign to="xport-smtp-mailfrom" from="//mailfrom/text()"/>
            <assign to="xport-smtp-mailhost" from="'frostarnett-com01c.mail.protection.outlook.com'"></assign>
            <assign to="xport-smtp-mailport">25</assign>
            <assign to="xport-smtp-mailto" from="//mailto/text()"/>
	    <assign to="xport-smtp-mailsubject">Automated Event Notification</assign>
            <assign to="." from="*"/>
          </output>
          <input message="inmsg">
            <assign to="." from="*"/>
          </input>
        </operation>
        
        <onFault>
          <sequence name="handle SMTP Send error">
            <operation>
              <participant name="XMLEncoder"/>
              <output message="Xout">
                <assign to="mode">process_data_to_document</assign>
                <assign to="xPath">/ProcessData/*[starts-with(local-name(.),'Prev_NotSuccess_Adv_Status')]</assign>
                <assign to="root_element">ErrorMessage</assign>
                <assign to="." from="*"/>
              </output>
              <input message="Xin">
                <assign to="." from="*"/>
              </input>
            </operation>
          </sequence>
        </onFault>

      </sequence>
              
      <!-- increment loop counter and continue with next iteration -->
      <assign to="index" from="number(number(index) + 1)"/>
      <repeat name="next user" ref="for each user"/>

    </sequence>
  </choice>
  <!-- 
    Adding onFault block to catch Exception from UserService when there is no email address. When exception
    throws, retrieve email address from datahelp@frost-arnett.com
  -->
  <onFault>
    <sequence name="handle unknown error">
      <operation>
        <participant name="XMLEncoder"/>
        <output message="Xout">
          <assign to="mode">process_data_to_document</assign>
          <assign to="xPath">/ProcessData/*[starts-with(local-name(.),'Prev_NotSuccess_Adv_Status')]</assign>
          <assign to="root_element">ErrorMessage</assign>
          <assign to="." from="*"/>
        </output>
        <input message="Xin">
          <assign to="." from="*"/>
        </input>
      </operation>
    </sequence>
  </onFault>
</sequence>
</process>

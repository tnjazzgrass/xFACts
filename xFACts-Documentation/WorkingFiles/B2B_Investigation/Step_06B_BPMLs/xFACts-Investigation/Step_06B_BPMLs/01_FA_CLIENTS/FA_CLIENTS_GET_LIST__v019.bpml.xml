<process name="FA_CLIENTS_GET_LIST">
  <rule name="More_Clients?">
    <condition>ClientCounter &lt;= NumOfClients</condition>
  </rule>

  <rule name="ETL?">
    <condition>//Result/Client[1]/ETL_PATH/text() != &apos;&apos;</condition>
  </rule>

  <rule name="UpdateRunFlag?">
    <condition>string(//SEQ_ID/text()) != &apos;&apos;</condition>
  </rule>

  <sequence name="Clients_List_Start">
    <operation name="This Service">
      <participant name="This"/>
      <output message="thisRequest">
      </output>
      <input message="inmsg">
        <assign to="parentID" from="this/node()"></assign>
      </input>
    </operation>

    <operation name="Lightweight JDBC Adapter">
      <participant name="AS2LightweightJDBCAdapter"/>
      <output message="LightweightJDBCAdapterTypeInputMessage">
        <assign to="." from="*"></assign>
        <assign to="param1" from="if(boolean(string(//CLIENT_ID/text()) = &apos;&apos;),0,//CLIENT_ID/text())"></assign>
        <assign to="param2" from="if(boolean(string(//SEQ_ID/text()) = &apos;&apos;),if(boolean(string(//CLIENT_ID/text()) = &apos;&apos;),0,&apos;-1&apos;),//SEQ_ID/text())"></assign>
        <assign to="param3" from="if(boolean(string(//SEQ_ID/text()) = &apos;&apos;),if(boolean(string(//CLIENT_ID/text()) = &apos;&apos;),0,&apos;-1&apos;),//SEQ_ID/text())"></assign>
        <assign to="param4" from="number(//parentID/INVOKE_ID_LIST/text())"></assign>
        <assign to="paramtype1">Integer</assign>
        <assign to="paramtype2">Integer</assign>
        <assign to="paramtype3">Integer</assign>
        <assign to="paramtype4">Integer</assign>
        <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
        <assign to="query_type">INSERT</assign>
        <assign to="result_name">Result</assign>
        <assign to="row_name">Client</assign>
        <assign to="sql">INSERT INTO INTEGRATION.ETL.tbl_B2B_CLIENTS_BATCH_STATUS(CLIENT_ID,SEQ_ID,RUN_ID) VALUES(?,CASE WHEN ? = -1 THEN NULL ELSE ? END,?)</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <operation name="Lightweight JDBC Adapter">
      <participant name="AS2LightweightJDBCAdapter"/>
      <output message="LightweightJDBCAdapterTypeInputMessage">
        <assign to="." from="*"></assign>
        <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
        <assign to="query_type">SELECT</assign>
        <assign to="result_name">Settings</assign>
        <assign to="row_name">Values</assign>
        <assign to="sql">EXEC faint.USP_B2B_CLIENTS_GET_SETTINGS</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
        <assign to="." from="DocToDOM(PrimaryDocument)"></assign>
      </input>
    </operation>

    <assign name="Assign" to="." from="DocToDOM(PrimaryDocument)"></assign>
    <operation name="Lightweight JDBC Adapter">
      <participant name="AS2LightweightJDBCAdapter"/>
      <output message="LightweightJDBCAdapterTypeInputMessage">
        <assign to="." from="*"></assign>
        <assign to="param1" from="//CLIENT_ID/text()"></assign>
        <assign to="param2" from="//SEQ_ID/text()"></assign>
        <assign to="param3" from="//SEQ_IDS/text()"></assign>
        <assign to="param4" from="//PROCESS_TYPE/text()"></assign>
        <assign to="param5" from="//SEQUENTIAL/text()"></assign>
        <assign to="paramtype1">Integer</assign>
        <assign to="paramtype2">Integer</assign>
        <assign to="paramtype3">String</assign>
        <assign to="paramtype4">String</assign>
        <assign to="paramtype5">Integer</assign>
        <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
        <assign to="query_type">SELECT</assign>
        <assign to="result_name">Result</assign>
        <assign to="row_name">Client</assign>
        <assign to="sql">EXEC faint.USP_B2B_CLIENTS_GET_LIST ?,?,?,?,?</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
        <assign to="." from="DocToDOM(PrimaryDocument)"></assign>
      </input>
    </operation>

    <assign name="Assign" to="ClientCounter">1</assign>
    <assign name="Assign" to="NumOfClients" from="count(DocToDOM(PrimaryDocument)//Client)"></assign>
    <sequence name="ClientsLoop">
      <choice name="Choice Start">
        <select>
          <case ref="More_Clients?" activity="Start_Processing"/>
        </select>

        <sequence name="Start_Processing">
          <operation name="This Service">
            <participant name="This"/>
            <output message="assignRequest">
              <assign to="from" from="concat(&apos;DocToDOM(PrimaryDocument)//Client[&apos;,//ClientCounter/text(),&apos;]&apos;)"></assign>
              <assign to="to" from="&apos;//Result&apos;"></assign>
            </output>
            <input message="assignResponse">
              <assign to="." from="*"></assign>
            </input>
          </operation>

          <choice name="Choice Start">
            <select>
              <case ref="ETL?" activity="ETL"/>
              <case ref="ETL?" negative="true" activity="BP"/>
            </select>

            <sequence name="ETL">
              <operation name="Invoke Business Process Service">
                <participant name="InvokeBusinessProcessService"/>
                <output message="InvokeBusinessProcessServiceTypeInputMessage">
                  <assign to="." from="*"></assign>
                  <assign to="WFD_NAME">FA_CLIENTS_ETL_CALL</assign>
                </output>
                <input message="inmsg">
                  <assign to="." from="*"></assign>
                </input>
              </operation>

            </sequence>
            <sequence name="BP">
              <operation name="Invoke Business Process Service">
                <participant name="InvokeBusinessProcessService"/>
                <output message="InvokeBusinessProcessServiceTypeInputMessage">
                  <assign to="." from="*"></assign>
                  <assign to="WFD_NAME">FA_CLIENTS_MAIN</assign>
                </output>
                <input message="inmsg">
                  <assign to="." from="*"></assign>
                </input>
              </operation>

            </sequence>
          </choice>
          <assign name="Assign" to="SavePrimaryDocument" from="//PrimaryDocument/@SCIObjectID"></assign>
          <operation name="Lightweight JDBC Adapter">
            <participant name="AS2LightweightJDBCAdapter"/>
            <output message="LightweightJDBCAdapterTypeInputMessage">
              <assign to="." from="*"></assign>
              <assign to="param1" from="number(//Result/Client/CLIENT_ID/text())"></assign>
              <assign to="param2" from="number(//Result/Client/SEQ_ID/text())"></assign>
              <assign to="paramtype1">Integer</assign>
              <assign to="paramtype2">Integer</assign>
              <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
              <assign to="query_type">UPDATE</assign>
              <assign to="result_name">Result</assign>
              <assign to="row_name">Client</assign>
              <assign to="sql">UPDATE etl.tbl_B2B_CLIENTS_FILES  SET RUN_FLAG = 0 WHERE CLIENT_ID = ? AND SEQ_ID = ?</assign>
            </output>
            <input message="inmsg">
              <assign to="." from="*"></assign>
              <assign to="." from="DocToDOM(PrimaryDocument)"></assign>
            </input>
          </operation>

          <assign name="Assign" to="PrimaryDocument" from="//SavePrimaryDocument/@SCIObjectID"></assign>
          <operation name="Release Service">
            <participant name="ReleaseService"/>
            <output message="outmsg">
              <assign to="TARGET">SavePrimaryDocument</assign>
            </output>
            <input message="inmsg">
            </input>
          </operation>

          <assign name="Assign" to="ClientCounter" from="ClientCounter+1"></assign>
          <repeat name="Repeat" ref="ClientsLoop"/>

        </sequence>
      </choice>
    </sequence>
    <operation name="Lightweight JDBC Adapter">
      <participant name="AS2LightweightJDBCAdapter"/>
      <output message="LightweightJDBCAdapterTypeInputMessage">
        <assign to="." from="*"></assign>
        <assign to="param1" from="number(//parentID/INVOKE_ID_LIST/text())"></assign>
        <assign to="paramtype1">Integer</assign>
        <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
        <assign to="query_type">UPDATE</assign>
        <assign to="result_name">Result</assign>
        <assign to="row_name">Client</assign>
        <assign to="sql">UPDATE INTEGRATION.ETL.tbl_B2B_CLIENTS_BATCH_STATUS SET BATCH_STATUS = 2, FINISH_DATE = GETDATE() WHERE RUN_ID = ?</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <onFault>
      <sequence name="GetListError">
        <operation name="Lightweight JDBC Adapter">
          <participant name="AS2LightweightJDBCAdapter"/>
          <output message="LightweightJDBCAdapterTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="param1" from="number(//parentID/INVOKE_ID_LIST/text())"></assign>
            <assign to="paramtype1">Integer</assign>
            <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
            <assign to="query_type">UPDATE</assign>
            <assign to="result_name">Result</assign>
            <assign to="row_name">Client</assign>
            <assign to="sql">UPDATE INTEGRATION.ETL.tbl_B2B_CLIENTS_BATCH_STATUS SET BATCH_STATUS = -1, FINISH_DATE = GETDATE() WHERE RUN_ID = ?</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="Lightweight JDBC Adapter">
          <participant name="AS2LightweightJDBCAdapter"/>
          <output message="LightweightJDBCAdapterTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="param1" from="if(boolean(string(//CLIENT_ID/text()) = &apos;&apos;),0,//CLIENT_ID/text())"></assign>
            <assign to="param2" from="if(boolean(string(//SEQ_ID/text()) = &apos;&apos;),0,//SEQ_ID/text())"></assign>
            <assign to="param3" from="number(//parentID/INVOKE_ID_LIST/text())"></assign>
            <assign to="param4" from="&apos;CLIENTS GET LIST&apos;"></assign>
            <assign to="paramtype1">Integer</assign>
            <assign to="paramtype2">Integer</assign>
            <assign to="paramtype3">Integer</assign>
            <assign to="paramtype4">String</assign>
            <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
            <assign to="query_type">INSERT</assign>
            <assign to="result_name">Result</assign>
            <assign to="row_name">Client</assign>
            <assign to="sql">INSERT INTO ETL.tbl_B2B_CLIENTS_TICKETS VALUES(NULL,?,?,?,?,NULL,&apos;MAP ERROR&apos;,GETDATE(),NULL)</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="Invoke Business Process Service">
          <participant name="InvokeBusinessProcessService"/>
          <output message="InvokeBusinessProcessServiceTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="WFD_NAME">EmailOnError</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </onFault>
  </sequence>
</process>

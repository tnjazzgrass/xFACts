<process name="FA_CLIENTS_FILE_MERGE">
  <rule name="Merge?">
    <condition>count(//MergedFiles) != 0</condition>
  </rule>

  <rule name="Update?">
    <condition>currentdoc = noofdocs and noofdocs != 1 and //Result/Client[1]/PROCESS_TYPE/text() = &apos;PAYMENT&apos;</condition>
  </rule>

  <sequence name="File_Merge">
    <choice name="Choice Start">
      <select>
        <case ref="Merge?" activity="StartMerge"/>
        <case ref="Merge?" negative="true" activity="NotMerge"/>
      </select>

      <sequence name="StartMerge">
        <assign name="Assign" to="BatchTotal1" from="if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;),&apos;0&apos;,count(DocToDOM(PrimaryDocument,&apos;false&apos;,&apos;false&apos;,&apos;//consumer-payment-imports&apos;)/*[name()=&apos;consumer-payment-imports&apos;]/*[name()=&apos;consumer-payment-import&apos;]) )"></assign>
        <operation name="DocumentsExtractService">
          <participant name="DocumentExtractionService"/>
          <output message="DocumentExtractionTypeInputMessage">
            <assign to="BatchLikeDocuments">NO</assign>
            <assign to="EDIEncodeDocument">NO</assign>
            <assign to="EDIEnvelopeDocument">NO</assign>
            <assign to="ErrorOnUnrecognizedData">NO</assign>
            <assign to="PDToProcessData">YES</assign>
            <assign to="XMLInput">YES</assign>
            <assign to="XMLRootTag" from="if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;),&apos;consumers&apos;,&apos;consumer-payment-imports&apos;)"></assign>
            <assign to="." from="*"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="AssignService">
          <participant name="AssignService"/>
          <output message="outmsg">
            <assign to="/ProcessData/PrimaryDocument" from="//MergedFiles/@SCIObjectID"></assign>
            <assign to="DOC-SPLIT-2" from="//DOC-SPLIT-1/@SCIObjectID"></assign>
            <assign to="BatchTotal2" from="count(DocToDOM(PrimaryDocument,&apos;false&apos;,&apos;false&apos;,&apos;//consumer-payment-imports&apos;)/*[name()=&apos;consumer-payment-imports&apos;]/*[name()=&apos;consumer-payment-import&apos;]) "></assign>
            <assign to="prefix_root" from="if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;),&apos;&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?&gt;&lt;newbiz xmlns=&quot;http://www.crsoftwareinc.com/xml/ns/titanium/common/v1_0&quot; xmlns:xsi=&quot;http://www.w3.org/2001/XMLSchema-instance&quot;&gt;  &lt;newbiz-header&gt;    &lt;total-consumers&gt;1&lt;/total-consumers&gt;    &lt;creditor-name/&gt;    &lt;total-principal&gt;1.0&lt;/total-principal&gt;    &lt;total-charge&gt;1.0&lt;/total-charge&gt;    &lt;total-interest&gt;1.0&lt;/total-interest&gt;    &lt;total-balance&gt;1.0&lt;/total-balance&gt;  &lt;/newbiz-header&gt;&apos;,concat(&apos;&lt;consumer-payment-import-job xmlns:xsi=&quot;http://www.w3.org/2001/XMLSchema-instance&quot; xsi:schemaLocation=&quot;http://www.crsoftwareinc.com/xml/ns/titanium/common/v1_0 consumer-payment-import-job.xsd&quot; xmlns=&quot;http://www.crsoftwareinc.com/xml/ns/titanium/common/v1_0&quot;&gt;  &lt;payment-import-header&gt;    &lt;client-code&gt;&apos;,//Result/Client[1]/CLIENT_NAME/text(),&apos;&lt;/client-code&gt;    &lt;batch-code&gt;BATCH&lt;/batch-code&gt;    &lt;batch-name&gt;BATCHNAME&apos;,//time/text(),&apos;&lt;/batch-name&gt;    &lt;number-of-accounts&gt;&apos;, number(//BatchTotal1/text()) + number(//BatchTotal2/text()),&apos;&lt;/number-of-accounts&gt;    &lt;total-value-of-account-payment&gt;0.00&lt;/total-value-of-account-payment&gt;    &lt;date-of-turnover&gt;&apos;,substring(//time/text(),1,4),&apos;-&apos;,substring(//time/text(),5,2),&apos;-&apos;,substring(//time/text(),7,2),&apos;&lt;/date-of-turnover&gt;    &lt;is-conversion-job&gt;false&lt;/is-conversion-job&gt;  &lt;/payment-import-header&gt;&apos;)) "></assign>
            <assign to="suffix_root" from="if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;),&apos;&lt;/newbiz&gt;&apos;,&apos;&lt;/consumer-payment-import-job&gt;&apos;)"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="DocumentsExtractService">
          <participant name="DocumentExtractionService"/>
          <output message="DocumentExtractionTypeInputMessage">
            <assign to="BatchLikeDocuments">NO</assign>
            <assign to="EDIEncodeDocument">NO</assign>
            <assign to="EDIEnvelopeDocument">NO</assign>
            <assign to="ErrorOnUnrecognizedData">NO</assign>
            <assign to="PDToProcessData">YES</assign>
            <assign to="XMLInput">YES</assign>
            <assign to="XMLRootTag" from="if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;),&apos;consumers&apos;,&apos;consumer-payment-imports&apos;)"></assign>
            <assign to="." from="*"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="MergeDocument">
          <participant name="MergeDocument"/>
          <output message="MergeDocumentInputMessage">
            <assign to="." from="*"></assign>
            <assign to="document1">DOC-SPLIT-1</assign>
            <assign to="document2">DOC-SPLIT-2</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="BatchProcessor">
          <participant name="BatchProcessorService"/>
          <output message="BatchProcessorInputMessage">
            <assign to="." from="*"></assign>
            <assign to="prefix_document">prefix_root</assign>
            <assign to="suffix_document">PrimaryDocument</assign>
            <assign to="use_xml">false</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="BatchProcessor">
          <participant name="BatchProcessorService"/>
          <output message="BatchProcessorInputMessage">
            <assign to="." from="*"></assign>
            <assign to="prefix_document">PrimaryDocument</assign>
            <assign to="suffix_document">suffix_root</assign>
            <assign to="use_xml">false</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="XSLT Service">
          <participant name="XSLTService"/>
          <output message="XSLTServiceTypeInputMessage">
            <assign to="additional_xslt_params" from="concat(&apos;param1=&apos;,//Result/Client[1]/PROCESS_TYPE/text())"></assign>
            <assign to="xml_input_from">PrimaryDoc</assign>
            <assign to="xml_input_validation">NO</assign>
            <assign to="xslt_name">FA_FILE_MERGE</assign>
            <assign to="." from="*"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="Release Service">
          <participant name="ReleaseService"/>
          <output message="outmsg">
            <assign to="TARGET">/ProcessData/*[name()= &apos;DOC-SPLIT-2&apos; or name()= &apos;DOC-SPLIT-1&apos; or name()= &apos;prefix_root&apos; or name()= &apos;suffix_root&apos; or name()= &apos;BatchTotal1&apos; or name()= &apos;BatchTotal2&apos;]</assign>
          </output>
          <input message="inmsg">
          </input>
        </operation>

        <assign name="Assign" to="MergedFiles" from="//PrimaryDocument/@SCIObjectID"></assign>
      </sequence>
      <sequence name="NotMerge">
        <assign name="Assign" to="MergedFiles" from="//PrimaryDocument/@SCIObjectID"></assign>
      </sequence>
    </choice>
    <choice>
      <select>
        <case ref="Update?" activity="UpdatePaymentNode"/>
      </select>

      <sequence name="UpdatePaymentNode">
        <operation name="XSLT Service">
          <participant name="XSLTService"/>
          <output message="XSLTServiceTypeInputMessage">
            <assign to="xml_input_from">PrimaryDoc</assign>
            <assign to="xml_input_validation">NO</assign>
            <assign to="xslt_name">FA_PAYMENT_NODE_COUNTER</assign>
            <assign to="." from="*"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
  </sequence>
</process>

<process name="FA_CLIENTS_ENCOUNTER_LOAD">
  <rule name="Encounter?">
    <condition>number(//ENCOUNTER_INFO/ENC_ID_ADD/text()) &gt; 0 or number(//ENCOUNTER_INFO/SERV_ID_ADD/text()) &gt; 0</condition>
  </rule>

  <sequence name="ENCOUNTER">
    <assign name="Assign" to="//PrimaryDocument" from="if(boolean(//Result/Client[1]/GET_DOCS_TYPE/text() = &apos;FSA_PULL&apos;),//*[ name() =  concat(&apos;FSA_Document&apos;,//currentdoc/text())]/@SCIObjectID,//*[ name() =  concat(&apos;SFTPPrimDoc&apos;,//currentdoc/text())]/@SCIObjectID)"></assign>
    <operation name="Translation">
      <participant name="Translation"/>
      <output message="TranslationTypeInputMessage">
        <assign to="." from="*"></assign>
        <assign to="map_name" from="//Result/Client[1]/ENCOUNTER_MAP/text()"></assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <assign name="Assign" to="//EncounterDocument" from="//PrimaryDocument/@SCIObjectID"></assign>
    <choice name="Choice Start">
      <select>
        <case ref="Encounter?" activity="ENC_INSERT"/>
      </select>

      <sequence name="ENC_INSERT">
        <operation name="Invoke Business Process Service">
          <participant name="InlineInvokeBusinessProcessService"/>
          <output message="InvokeBusinessProcessServiceTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
            <assign to="WFD_NAME">FA_CLIENTS_ENCOUNTER_ID</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <assign name="Assign" to="//PrimaryDocument" from="//EncounterDocument/@SCIObjectID"></assign>
        <operation name="Translation">
          <participant name="Translation"/>
          <output message="TranslationTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="map_name">FA_CLIENTS_ENCOUNTER_LOAD_D2S</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
    <onFault>
      <sequence name="on_Fail">
        <operation name="Invoke Business Process Service">
          <participant name="InvokeBusinessProcessService"/>
          <output message="InvokeBusinessProcessServiceTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="INVOKE_MODE">ASYNC</assign>
            <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
            <assign to="WFD_NAME">EmailOnError</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </onFault>
  </sequence>
</process>

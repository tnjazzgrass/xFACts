<process name="FA_CLIENTS_EMAIL">
  <rule name="SimpleEmailFile?">
    <condition>contains(string(//Result/Client[1]/PROCESS_TYPE/text()),&apos;EMAIL&apos;)</condition>
  </rule>

  <rule name="FSAPull?">
    <condition>//Result/Client[1]/GET_DOCS_TYPE/text() = &apos;FSA_PULL&apos;</condition>
  </rule>

  <rule name="MoreFiles?">
    <condition>currentdoc &lt;= noofdocs</condition>
  </rule>

  <rule name="SFTPPull?">
    <condition>(//Result/Client[1]/GET_DOCS_TYPE/text() = &apos;SFTP_PULL&apos; or contains(string(//Result/Client[1]/PROCESS_TYPE/text()),&apos;EMAIL&apos;)) and string(//Result/Client[1]/GET_DOCS_TYPE/text()) != &apos;FSA_PULL&apos;</condition>
  </rule>

  <rule name="XSLTEmail?">
    <condition>string(//Result/Client[1]/EMAIL_XSLT/text()) != &apos;&apos;</condition>
  </rule>

  <rule name="EmailSubject?">
    <condition>string(//Result/Client/EMAIL_SUBJECT/text()) != &apos;&apos;</condition>
  </rule>

  <sequence name="EmailStart">
    <choice name="Choice Start">
      <select>
        <case ref="EmailSubject?" activity="EmailSubject"/>
      </select>

      <sequence name="EmailSubject">
        <operation name="This Service">
          <participant name="This"/>
          <output message="assignRequest">
            <assign to="from" from="//Result/Client/EMAIL_SUBJECT/text()"></assign>
            <assign to="to" from="&apos;//Result/Client/EMAIL_SUBJECT&apos;"></assign>
          </output>
          <input message="assignResponse">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
    <choice name="Choice Start">
      <select>
        <case ref="SimpleEmailFile?" activity="SimpleEmail"/>
      </select>

      <sequence name="SimpleEmail">
        <choice name="Choice Start">
          <select>
            <case ref="FSAPull?" activity="FSASend"/>
          </select>

          <sequence name="FSASend">
            <operation name="Mail Mime Service">
              <participant name="MailMimeService"/>
              <output message="MailMimeServiceInputMessage">
                <assign to="." from="*"></assign>
                <assign to="mail-mime-body">false</assign>
                <assign to="mail-mime-cc" from="//Result/Client[1]/MAIL_CC/text()"></assign>
                <assign to="mail-mime-operation">build</assign>
                <assign to="mail-mime-recipient" from="//Result/Client[1]/MAIL_TO/text()"></assign>
                <assign to="mail-mime-sender">datahelp@frost-arnett.com</assign>
                <assign to="mail-mime-set-attachment">true</assign>
                <assign to="mail-mime-subject" from="if(boolean(//Result/Client/EMAIL_SUBJECT/text() != &apos;&apos;),concat(if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;&apos;,&apos;TEST &apos;),//Result/Client/EMAIL_SUBJECT/text()),concat(if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;&apos;,&apos;TEST &apos;),//Result/Client[1]/CLIENT_NAME/text(),&apos; Files for &apos;,concat(substring(//time/text(),5,2),&apos;/&apos;,substring(//time/text(),7,2),&apos;/&apos;,substring(//time/text(),1,4))))"></assign>
                <assign to="mail-mime-use-doc-area">true</assign>
              </output>
              <input message="inmsg">
                <assign to="." from="*"></assign>
              </input>
            </operation>

          </sequence>
        </choice>
        <choice name="Choice Start">
          <select>
            <case ref="SFTPPull?" activity="SFTPLoop"/>
          </select>

          <sequence name="SFTPLoop">
            <assign name="Assign" to="currentdoc">1</assign>
            <operation name="Release Service">
              <participant name="ReleaseService"/>
              <output message="outmsg">
                <assign to="TARGET">/ProcessData/*[contains(name(),&apos;Document&apos;) or name() = &apos;assignedFilename&apos; or name() = &apos;FileName&apos;]</assign>
              </output>
              <input message="inmsg">
              </input>
            </operation>

            <sequence name="StartStep">
              <choice name="Choice Start">
                <select>
                  <case ref="MoreFiles?" activity="Loop"/>
                </select>

                <sequence name="Loop">
                  <operation name="Release Service">
                    <participant name="ReleaseService"/>
                    <output message="outmsg">
                      <assign to="TARGET">/ProcessData/*[name()= &apos;DocumentName&apos; or name()= &apos;BodyName&apos; or name()= &apos;DocumentInitialId&apos; or name()= &apos;PrimaryDocument&apos; or name()= &apos;assignedFilename&apos;]</assign>
                    </output>
                    <input message="inmsg">
                    </input>
                  </operation>

                  <assign name="Assign" to="/ProcessData/PrimaryDocument" from="//*[ name() =  concat(&apos;SavedPrimDoc&apos;,//currentdoc/text())]/@SCIObjectID"></assign>
                  <operation name="Mail Mime Service">
                    <participant name="MailMimeService"/>
                    <output message="MailMimeServiceInputMessage">
                      <assign to="." from="*"></assign>
                      <assign to="mail-mime-body">false</assign>
                      <assign to="mail-mime-cc" from="//Result/Client[1]/MAIL_CC/text()"></assign>
                      <assign to="mail-mime-operation">build</assign>
                      <assign to="mail-mime-recipient" from="//Result/Client[1]/MAIL_TO/text()"></assign>
                      <assign to="mail-mime-sender">datahelp@frost-arnett.com</assign>
                      <assign to="mail-mime-set-attachment">true</assign>
                      <assign to="mail-mime-subject" from="if(boolean(//Result/Client/EMAIL_SUBJECT/text() != &apos;&apos;),concat(if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;&apos;,&apos;TEST &apos;),//Result/Client/EMAIL_SUBJECT/text()),concat(if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;&apos;,&apos;TEST &apos;),//Result/Client[1]/CLIENT_NAME/text(),&apos; Files for &apos;,concat(substring(//time/text(),5,2),&apos;/&apos;,substring(//time/text(),7,2),&apos;/&apos;,substring(//time/text(),1,4))))"></assign>
                      <assign to="mail-mime-use-doc-area">true</assign>
                    </output>
                    <input message="inmsg">
                      <assign to="." from="*"></assign>
                    </input>
                  </operation>

                  <assign name="Assign" to="currentdoc" from="currentdoc+1"></assign>
                  <repeat name="Repeat" ref="StartStep"/>

                </sequence>
              </choice>
            </sequence>
          </sequence>
        </choice>
        <operation name="SMTP Send Adapter">
          <participant name="SMTP_SEND_ADAPTER"/>
          <output message="MailMimeServiceInputMessage">
            <assign to="." from="*"></assign>
            <assign to="b2b-raw-message">true</assign>
            <assign to="xport-smtp-mailCC" from="//Result/Client[1]/MAIL_CC/text()"></assign>
            <assign to="xport-smtp-mailfrom">datahelp@frost-arnett.com</assign>
            <assign to="xport-smtp-mailhost">frostarnett-com01c.mail.protection.outlook.com</assign>
            <assign to="xport-smtp-mailport">25</assign>
            <assign to="xport-smtp-mailto" from="//Result/Client[1]/MAIL_TO/text()"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
    <choice name="Choice Start">
      <select>
        <case ref="XSLTEmail?" activity="XSLTEmail"/>
      </select>

      <sequence name="XSLTEmail">
        <operation name="Release Service">
          <participant name="ReleaseService"/>
          <output message="outmsg">
            <assign to="TARGET">/ProcessData/*/@SCIObjectID/parent::*</assign>
          </output>
          <input message="inmsg">
          </input>
        </operation>

        <operation name="XSLTService">
          <participant name="XSLTService"/>
          <output message="XSLTServiceInputMessage">
            <assign to="input_pd_xpath">/</assign>
            <assign to="xml_input_from">ProcData</assign>
            <assign to="xml_input_validation">NO</assign>
            <assign to="xslt_name" from="//Result/Client[1]/EMAIL_XSLT/text()"></assign>
            <assign to="." from="*"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="Mail Mime Service">
          <participant name="MailMimeService"/>
          <output message="MailMimeServiceInputMessage">
            <assign to="mail-mime-body">true</assign>
            <assign to="mail-mime-cc" from="//Result/Client[1]/MAIL_CC/text()"></assign>
            <assign to="mail-mime-operation">build</assign>
            <assign to="mail-mime-recipient" from="//Result/Client[1]/MAIL_TO/text()"></assign>
            <assign to="mail-mime-sender">datahelp@frost-arnett.com</assign>
            <assign to="mail-mime-set-attachment">false</assign>
            <assign to="mail-mime-subject" from="if(boolean(//Result/Client/EMAIL_SUBJECT/text() != &apos;&apos;),concat(if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;&apos;,&apos;TEST &apos;),//Result/Client/EMAIL_SUBJECT/text()),concat(if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;&apos;,&apos;TEST &apos;),//Result/Client[1]/CLIENT_NAME/text(),&apos; Files for &apos;,concat(substring(//time/text(),5,2),&apos;/&apos;,substring(//time/text(),7,2),&apos;/&apos;,substring(//time/text(),1,4))))"></assign>
            <assign to="mail-mime-use-doc-area">true</assign>
            <assign to="." from="*"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="SMTP Send Email">
          <participant name="SMTP_SEND_ADAPTER"/>
          <output message="Xout">
            <assign to="." from="*"></assign>
            <assign to="b2b-raw-message">true</assign>
            <assign to="xport-smtp-mailCC" from="//Result/Client[1]/MAIL_CC/text()"></assign>
            <assign to="xport-smtp-mailfrom">datahelp@frost-arnett.com</assign>
            <assign to="xport-smtp-mailhost">frostarnett-com01c.mail.protection.outlook.com</assign>
            <assign to="xport-smtp-mailport">25</assign>
            <assign to="xport-smtp-mailto" from="//Result/Client[1]/MAIL_TO/text()"></assign>
            <assign to="xport-b2b-mode">off</assign>
          </output>
          <input message="Xin">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
    <onFault>
      <operation name="Invoke Business Process Service">
        <participant name="InvokeBusinessProcessService"/>
        <output message="InvokeBusinessProcessServiceTypeInputMessage">
          <assign to="." from="*"></assign>
          <assign to="INVOKE_MODE">ASYNC</assign>
          <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
          <assign to="WFD_NAME">EmailOnError</assign>
        </output>
        <input message="inmsg">
          <assign to="." from="*"></assign>
        </input>
      </operation>

    </onFault>
  </sequence>
</process>

<process name="FA_CLIENTS_ARCHIVE">
  <rule name="PreArchive?">
    <condition>//PreArchiveFlag = 1</condition>
  </rule>

  <rule name="PostArchive?">
    <condition>//PostArchiveFlag = 1 or //PostArchiveFlag = 2</condition>
  </rule>

  <sequence name="MoveStart">
    <choice name="Choice Start">
      <select>
        <case ref="PreArchive?" activity="PreArchiveStart"/>
      </select>

      <sequence name="PreArchiveStart">
        <operation name="File System Adapter">
          <participant name="AS2Extract"/>
          <output message="FileSystemInputMessage">
            <assign to="." from="*"></assign>
            <assign to="Action">FS_EXTRACT</assign>
            <assign to="extractionFolder" from="concat(//Result/Client[1]/PRE_ARCHIVE/text(),&apos;\&apos;,substring(//time/text(),1,4),&apos;\&apos;,substring(//time/text(),5,2),&apos;\&apos;,substring(//time/text(),7,2))   "></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
    <choice name="Choice Start">
      <select>
        <case ref="PostArchive?" activity="PostArchiveStart"/>
      </select>

      <sequence name="PostArchiveStart">
        <operation name="File System Adapter">
          <participant name="AS2Extract"/>
          <output message="FileSystemInputMessage">
            <assign to="." from="*"></assign>
            <assign to="Action">FS_EXTRACT</assign>
            <assign to="assignedFilename" from="if(boolean(//PostArchiveFlag = 1),concat(//assignedFilename/text(),&apos;.trans&apos;),//FinalFileName/text())"></assign>
            <assign to="assignFilename" from="if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;PAYMENT&apos; or //Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos; or //Result/Client[1]/PROCESS_TYPE/text() = &apos;BDL&apos;),&apos;true&apos;,&apos;false&apos;)"></assign>
            <assign to="extractionFolder" from="concat(//Result/Client[1]/POST_ARCHIVE/text(),&apos;\&apos;,substring(//time/text(),1,4),&apos;\&apos;,substring(//time/text(),5,2),&apos;\&apos;,substring(//time/text(),7,2)) "></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
  </sequence>
</process>

<process name="FA_CLIENTS_DUP_CHECK">
  <rule name="Dups?">
    <condition>substring(//DupCheck/Values/Dup_Nodes/text(),1,string-length(//DupCheck/Values/Dup_Nodes/text())-1) != &apos;param1=,&apos; and not(contains(//DupCheck/Values/Dup_Nodes/text(),&apos;DUPLICATE_FILE&apos;))</condition>
  </rule>

  <rule name="AllDups?">
    <condition>contains(//DupCheck/Values/Dup_Nodes/text(),&apos;DUPLICATE_FILE&apos;)</condition>
  </rule>

  <sequence name="DupCheck">
    <operation name="Release Service">
      <participant name="ReleaseService"/>
      <output message="outmsg">
        <assign to="TARGET">StatusReport</assign>
      </output>
      <input message="inmsg">
      </input>
    </operation>

    <operation name="Command Line 2 Adapter">
      <participant name="FA_CLA_DM_API"/>
      <output message="CmdLine2InputMessage">
        <assign to="." from="*"></assign>
        <assign to="cmdLine">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_INT_DUP_CHECK\FA_DUP_CHECK_CALL.exe $0 $1 $2</assign>
        <assign to="inputDelete">false</assign>
        <assign to="outputDelete">false</assign>
        <assign to="parm0" from="//thisProcessInstance/INVOKE_ID_LIST/text()"></assign>
        <assign to="parm1" from="if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;DM-PROD-APP3&apos;,&apos;DM-TEST-APP&apos;)"></assign>
        <assign to="parm2" from="string(//Result/Client[1]/DUP_CHECK/text())"></assign>
        <assign to="setSoTimeout">36000000</assign>
        <assign to="workingDir">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_INT_DUP_CHECK</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
        <assign to="." from="Status_Rpt(&apos;StatusReport&apos;)"></assign>
      </input>
    </operation>

    <operation name="AssignService">
      <participant name="AssignService"/>
      <output message="outmsg">
        <assign to="//DupCheck/Values/Dup_Nodes" from="substring(substring(//StatusReport,8),1,string-length(substring(//StatusReport,8))-1)"></assign>
        <assign to="PrimaryDocument" from="//MergedFiles/@SCIObjectID"></assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <choice name="Choice Start">
      <select>
        <case ref="Dups?" activity="RemoveDups"/>
        <case ref="Dups?" negative="true" activity="AllDups"/>
      </select>

      <sequence name="RemoveDups">
        <operation name="XSLT Service">
          <participant name="XSLTService"/>
          <output message="XSLTServiceTypeInputMessage">
            <assign to="additional_xslt_params" from="//DupCheck/Values/Dup_Nodes/text()"></assign>
            <assign to="xml_input_from">PrimaryDoc</assign>
            <assign to="xml_input_validation">NO</assign>
            <assign to="xslt_name">FA_DUP_CHECK</assign>
            <assign to="." from="*"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <assign name="Assign" to="MergedFiles" from="//PrimaryDocument/@SCIObjectID"></assign>
      </sequence>
      <sequence name="AllDups">
        <choice name="Choice Start">
          <select>
            <case ref="AllDups?" activity="AllDupsFlag"/>
          </select>

          <sequence name="AllDupsFlag">
            <assign name="Assign" to="DUPLICATE_FILE">Y</assign>
          </sequence>
        </choice>
      </sequence>
    </choice>
  </sequence>
</process>

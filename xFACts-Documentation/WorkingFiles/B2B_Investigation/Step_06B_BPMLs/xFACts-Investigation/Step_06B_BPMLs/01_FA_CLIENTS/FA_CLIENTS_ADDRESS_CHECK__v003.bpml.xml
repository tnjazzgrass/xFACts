<process name = "FA_CLIENTS_ADDRESS_CHECK"> 
  <sequence name="AddressLookup">
    <operation name="Command Line 2 Adapter">
      <participant name="FA_CLA_DM_API"/>
      <output message="CmdLine2InputMessage">
        <assign to="." from="*"></assign>
        <assign to="cmdLine">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_PERVASIVE_ADDRESS_LOOKUP\FA_PV_ADDRESS_UPDATE.exe $0 $1 $2 $3</assign>
        <assign to="inputDelete">false</assign>
        <assign to="outputDelete">false</assign>
        <assign to="parm0" from="//thisProcessInstance/INVOKE_ID_LIST/text()"></assign>
        <assign to="parm1" from="concat(//Result/Client/POST_ARCHIVE/text(),&apos;\&apos;,substring(//time/text(),1,4),&apos;\&apos;,substring(//time/text(),5,2),&apos;\&apos;,substring(//time/text(),7,2),&apos;\&apos;,//FinalFileName/text())"></assign>
        <assign to="parm2" from="string(//Result/Client/PV_FN_ADDRESS/text())"></assign>
        <assign to="parm3" from="if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;DM-PROD-APP3&apos;,&apos;DM-TEST-APP&apos;)"></assign>
        <assign to="setSoTimeout">4800000</assign>
        <assign to="workingDir">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_PERVASIVE_ADDRESS_LOOKUP</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
        <assign to="." from="Status_Rpt(&apos;StatusReport&apos;)"></assign>
      </input>
    </operation>

    <operation name="File System Adapter">
      <participant name="AS3FSAdapter"/>
      <output message="FileSystemInputMessage">
        <assign to="Action">FS_COLLECT</assign>
        <assign to="assignFilename">false</assign>
        <assign to="bootstrap">false</assign>
        <assign to="collectionFolder" from="concat(//Result/Client/POST_ARCHIVE/text(),&apos;\&apos;,substring(//time/text(),1,4),&apos;\&apos;,substring(//time/text(),5,2),&apos;\&apos;,substring(//time/text(),7,2))"></assign>
        <assign to="collectMultiple">false</assign>
        <assign to="collectZeroByteFiles">false</assign>
        <assign to="deleteAfterCollect">false</assign>
        <assign to="docStorageType">db</assign>
        <assign to="fileModTimeThreshold">1</assign>
        <assign to="filter" from="//FinalFileName/text()"></assign>
        <assign to="noFilesSetSuccess">true</assign>
        <assign to="useSubFolders">false</assign>
        <assign to="." from="*"></assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

  </sequence>
</process>


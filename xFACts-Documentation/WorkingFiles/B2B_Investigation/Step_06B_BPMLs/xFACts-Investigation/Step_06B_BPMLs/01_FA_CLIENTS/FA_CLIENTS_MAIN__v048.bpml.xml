<process name = "FA_CLIENTS_MAIN"> 
  <rule name="AnyMoreDocs?">
    <condition>currentdoc &lt;= noofdocs</condition>
  </rule>

  <rule name="Prep?">
    <condition>//Result/Client[1]/PREPARE_SOURCE/text() = &apos;Y&apos;
</condition>
  </rule>

  <rule name="PreArchive?">
    <condition>(//Result/Client[1]/PRE_ARCHIVE/text() != &apos;N&apos; ) and (count(//Files/File) != 0 or FSA_DocumentCount &gt; 0)</condition>
  </rule>

  <rule name="Translate?">
    <condition>string(//Result/Client[1]/TRANSLATION_MAP/text()) != &apos;&apos;</condition>
  </rule>

  <rule name="DupCheck?">
    <condition>string(//Result/Client[1]/DUP_CHECK/text()) != &apos;&apos; and string(//Result/Client[1]/DUP_CHECK/text()) != &apos;N&apos; and count(//Files/File) != 0</condition>
  </rule>

  <rule name="WorkersComp?">
    <condition>//Result/Client[1]/WORKERS_COMP/text() = &apos;Y&apos; and count(//Files/File) != 0 and string(//DUPLICATE_FILE/text())  = &apos;&apos;</condition>
  </rule>

  <rule name="PostArchive?">
    <condition>(//Result/Client[1]/POST_ARCHIVE/text() != &apos;N&apos; or //Result/Client[1]/POST_ARCHIVE/text() != &apos;&apos;) and (count(//Files/File) != 0 or //Result/Client[1]/COMM_METHOD/text() = &apos;OUTBOUND&apos;) </condition>
  </rule>

  <rule name="SendEmail?">
    <condition>(//Result/Client[1]/MAIL_TO/text() != &apos;&apos; and count(//Files/File) != 0 and EmptyFile = 0) or (//Result/Client[1]/MAIL_TO/text() != &apos;&apos; and (//Result/Client[1]/COMM_METHOD/text() = &apos;OUTBOUND&apos; or noofdocs &gt; 0))</condition>
  </rule>

  <rule name="CommCall?">
    <condition>string(//Result/Client/COMM_CALL/text()) = &apos;Y&apos;</condition>
  </rule>

  <rule name="MergeFiles?">
    <condition>string(//Result/Client[1]/POST_TRANSLATION_MAP/text()) = &apos;&apos; and //Result/Client[1]/TRANSLATION_MAP/text() != &apos;&apos; and count(//Files/File) != 0 and (//Result/Client[1]/PROCESS_TYPE/text() = &apos;PAYMENT&apos; or //Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;)</condition>
  </rule>

  <rule name="PrepCommCall?">
    <condition>(//Result/Client[1]/PROCESS_TYPE/text() != &apos;NEW_BUSINESS&apos; and //Result/Client[1]/PROCESS_TYPE/text() != &apos;PAYMENT&apos; and (//Result/Client[1]/PREPARE_COMM_CALL/text() = &apos;Y&apos; or //Result/Client[1]/COMM_METHOD/text() = &apos;OUTBOUND&apos;)) or ((//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos; or //Result/Client[1]/PROCESS_TYPE/text() = &apos;PAYMENT&apos;) and count(//Files/File) != 0 and string(//DUPLICATE_FILE/text())  = &apos;&apos; and EmptyFile = 0)</condition>
  </rule>

  <rule name="VITAL?">
    <condition>//Result/Client[1]/PROCESS_TYPE/text() != &apos;SFTP_PULL&apos;</condition>
  </rule>

  <rule name="PostArchive2?">
    <condition>//Result/Client[1]/POST_ARCHIVE/text() != &apos;N&apos; and count(//Files/File) != 0 and (//Result/Client[1]/PROCESS_TYPE/text() = &apos;PAYMENT&apos; or //Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;)</condition>
  </rule>

  <rule name="Wait?">
    <condition>//Result/Client[1]/PREV_SEQ/text() != &apos;&apos; and (//Ready/text() = -999 or (number(//Ready/text()) &gt;= 0 and number(//Ready/text() &lt;= 2)))</condition>
  </rule>

  <rule name="Continue?">
    <condition>//Ready/text() = -999 or (number(//Ready/text()) &lt;= 5 and number(//Ready/text() &gt;= 3))</condition>
  </rule>

  <rule name="NB?">
    <condition>//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;</condition>
  </rule>

  <rule name="Encounter?">
    <condition>string(//Result/Client[1]/ENCOUNTER_MAP/text()) != &apos;&apos;</condition>
  </rule>

  <rule name="AddressLookup?">
    <condition>string(//Result/Client[1]/PV_FN_ADDRESS/text()) != &apos;&apos; and string(//Result/Client[1]/PV_FN_ADDRESS/text()) != &apos;N&apos; and count(//Files/File) != 0</condition>
  </rule>

  <rule name="SaveDoc?">
    <condition>//Result/Client[1]/FILE_RENAME/text() = &apos;Y&apos;</condition>
  </rule>

  <rule name="PostTranslation?">
    <condition>string(//Result/Client[1]/POST_TRANSLATION/text()) = &apos;Y&apos;</condition>
  </rule>

  <rule name="PostTranslationVITAL?">
    <condition>string(//Result/Client[1]/POST_TRANSLATION_VITAL/text()) = &apos;Y&apos;</condition>
  </rule>

  <rule name="TranslationStaging?">
    <condition>string(//Result/Client/TRANSLATION_STAGING/text()) = &apos;Y&apos;</condition>
  </rule>

  <rule name="RemoveSpecialCharacters?">
    <condition>string(//Result/Client[1]/FILE_CLEAN_UP/text()) = &apos;Y&apos; and string(//Result/Client[1]/PREP_TRANSLATION_MAP/text()) = &apos;&apos;</condition>
  </rule>

  <sequence name="Receive File">
    <operation name="Release Service">
      <participant name="ReleaseService"/>
      <output message="outmsg">
        <assign to="TARGET">/ProcessData/*[name()= &apos;INVOKE_ID_LIST&apos; or name()= &apos;PrimaryDocument&apos;]</assign>
      </output>
      <input message="inmsg">
      </input>
    </operation>

    <operation name="This Service">
      <participant name="This"/>
      <output message="thisRequest">
      </output>
      <input message="inmsg">
        <assign to="thisProcessInstance" from="this/node()"></assign>
      </input>
    </operation>

    <operation name="Timestamp Utility">
      <participant name="TimestampUtilService"/>
      <output message="TimestampUtilServiceTypeInputMessage">
        <assign to="." from="*"></assign>
        <assign to="action">current_time</assign>
        <assign to="format">yyyyMMdd</assign>
        <assign to="scale">day</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <operation name="AssignService">
      <participant name="AssignService"/>
      <output message="outmsg">
        <assign to="Ready">-999</assign>
        <assign to="ClientArchiveName" from="if(boolean(//Result/Client[1]/GET_DOCS_TYPE/text() = &apos;SFTP_PULL&apos; and //Result/Client[1]/COMM_METHOD/text() = &apos;INBOUND&apos;),//Result/Client[1]/GET_DOCS_LOC/text(),translate(//Result/Client[1]/CLIENT_NAME/text(),&apos; &apos;,&apos;_&apos;))"></assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <operation name="Lightweight JDBC Adapter">
      <participant name="AS2LightweightJDBCAdapter"/>
      <output message="LightweightJDBCAdapterTypeInputMessage">
        <assign to="." from="*"></assign>
        <assign to="param1" from="number(//Result/Client[1]/CLIENT_ID/text())"></assign>
        <assign to="param2" from="number(//Result/Client[1]/SEQ_ID/text())"></assign>
        <assign to="param3" from="number(//thisProcessInstance/INVOKE_ID_LIST/text())"></assign>
        <assign to="param4" from="number(//parentID/INVOKE_ID_LIST/text())"></assign>
        <assign to="paramtype1">Integer</assign>
        <assign to="paramtype2">Integer</assign>
        <assign to="paramtype3">Integer</assign>
        <assign to="paramtype4">Integer</assign>
        <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
        <assign to="query_type">INSERT</assign>
        <assign to="result_name">Result</assign>
        <assign to="row_name">Client</assign>
        <assign to="sql">INSERT INTO INTEGRATION.ETL.tbl_B2B_CLIENTS_BATCH_STATUS(CLIENT_ID,SEQ_ID,RUN_ID,PARENT_ID) VALUES(?,?,?,?)</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <sequence name="StatusUpdate">
      <choice name="Choice Start">
        <select>
          <case ref="Wait?" activity="WaitProcess"/>
        </select>

        <sequence name="WaitProcess">
          <operation name="Wait">
            <participant name="WaitService"/>
            <output message="WaitServiceTypeInputMessage">
              <assign to="." from="*"></assign>
              <assign to="WAIT_INTERVAL">1</assign>
            </output>
            <input message="inmsg">
              <assign to="." from="*"></assign>
            </input>
          </operation>

          <operation name="Lightweight JDBC Adapter">
            <participant name="AS2LightweightJDBCAdapter"/>
            <output message="LightweightJDBCAdapterTypeInputMessage">
              <assign to="." from="*"></assign>
              <assign to="param1" from="number(//Result/Client[1]/CLIENT_ID/text())"></assign>
              <assign to="param2" from="number(//Result/Client[1]/PREV_SEQ/text())"></assign>
              <assign to="param3" from="number(//parentID/INVOKE_ID_LIST/text())"></assign>
              <assign to="paramtype1">Integer</assign>
              <assign to="paramtype2">Integer</assign>
              <assign to="paramtype3">Integer</assign>
              <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
              <assign to="query_type">SELECT</assign>
              <assign to="result_name">Result</assign>
              <assign to="row_name">Ready</assign>
              <assign to="sql">SELECT CASE WHEN BATCH_STATUS = -2 THEN -1 ELSE BATCH_STATUS END AS BATCH_STATUS  FROM ETL.tbl_B2B_CLIENTS_BATCH_STATUS WHERE CLIENT_ID = ? AND SEQ_ID = ?  AND PARENT_ID = ?</assign>
            </output>
            <input message="inmsg">
              <assign to="Ready" from="DocToDOM(PrimaryDocument)//Ready/BATCH_STATUS[1]/text()"></assign>
            </input>
          </operation>

          <repeat name="Repeat" ref="StatusUpdate"/>

        </sequence>
      </choice>
    </sequence>
    <operation name="Release Service">
      <participant name="ReleaseService"/>
      <output message="outmsg">
        <assign to="TARGET">PrimaryDocument</assign>
      </output>
      <input message="inmsg">
      </input>
    </operation>

    <choice name="Choice Start">
      <select>
        <case ref="Continue?" activity="Start_Process"/>
      </select>

      <sequence name="Start_Process">
        <operation name="Invoke Business Process Service">
          <participant name="InlineInvokeBusinessProcessService"/>
          <output message="InvokeBusinessProcessServiceTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
            <assign to="WFD_NAME">FA_CLIENTS_GET_DOCS</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="AssignService">
          <participant name="AssignService"/>
          <output message="outmsg">
            <assign to="currentdoc">1</assign>
            <assign to="noofdocs" from="if(boolean(//Result/Client[1]/COMM_METHOD/text() = &apos;OUTBOUND&apos; and string(//Result/Client[1]/GET_DOCS_TYPE/text()) = &apos;&apos;),number(string-length(//Result/Client[1]/FILE_FILTER/text()) - string-length(translate(//Result/Client[1]/FILE_FILTER/text(), &apos;|&apos;, &apos;&apos;))) + 1,if(boolean(//Result/Client[1]/GET_DOCS_TYPE/text() = &apos;FSA_PULL&apos;),//FSA_DocumentCount/text(),count(//DocumentList/DocumentId))) "></assign>
            <assign to="NodeCounter">0</assign>
            <assign to="//Result/Client/GET_DOCS_LOC" from="if(boolean(contains(//Result/Client/GET_DOCS_LOC/text(),&apos;/&apos;)),substring-before(//Result/Client/GET_DOCS_LOC/text(),&apos;/&apos;),//Result/Client/GET_DOCS_LOC/text())"></assign>
            <assign to="ClientArchiveName" from=" if(boolean(contains(//ClientArchiveName/text(),&apos;/&apos;)),substring-before(//ClientArchiveName/text(),&apos;/&apos;),//ClientArchiveName/text())"></assign>
            <assign to="EmptyFile" from="if(boolean(//Result/Client/PROCESS_TYPE/text() = &apos;PAYMENT&apos;),1,0)"></assign>
            <assign to="//Result/Client/POST_ARCHIVE" from="if(boolean(//Result/Client[1]/POST_ARCHIVE/text() = &apos;Y&apos;),concat(//Settings/Values/DEF_POST_ARCHIVE/text(),&apos;\&apos;,//Result/Client[1]/COMM_METHOD/text(),&apos;\&apos;,//ClientArchiveName/text()),//Result/Client[1]/POST_ARCHIVE/text())  "></assign>
            <assign to="FinalFileName" from="concat(translate(//Result/Client[1]/CLIENT_NAME/text(), &apos; &apos;, &apos;_&apos;),&apos;.DM.&apos;,//time/text(),&apos;_&apos;,//thisProcessInstance/INVOKE_ID_LIST/text(),if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;),&apos;.NB&apos;,if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;PAYMENT&apos;),&apos;.PAY&apos;,if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;BDL&apos;),&apos;.BDL&apos;,&apos;.&apos;))),&apos;.txt&apos;)"></assign>
            <assign to="//Result/Client/FILE_CLEAN_UP" from="if(boolean((string(//Result/Client[1]/PREP_TRANSLATION_MAP/text()) = &apos;&apos; or string(//Result/Client[1]/UNZIP_FILTER/text()) = &apos;&apos;) and string(//Result/Client[1]/COMM_METHOD/text()) != &apos;OUTBOUND&apos; and string(//Result/Client[1]/PROCESS_TYPE/text()) != &apos;SIMPLE_EMAIL&apos; and string(//Result/Client[1]/PROCESS_TYPE/text()) != &apos;SFTP_PUSH&apos; and string(//Result/Client[1]/PROCESS_TYPE/text()) != &apos;SFTP_PULL&apos; and string(//Result/Client[1]/PROCESS_TYPE/text()) != &apos;FILE_DELETION&apos; and string(//Result/Client[1]/FILE_CLEAN_UP/text()) != &apos;N&apos;),&apos;Y&apos;,&apos;N&apos;)"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <sequence name="LoopThruDocs">
          <choice name="Choice Start">
            <select>
              <case ref="AnyMoreDocs?" activity="ExtractAndProcess"/>
            </select>

            <sequence name="ExtractAndProcess">
              <operation name="AssignService">
                <participant name="AssignService"/>
                <output message="outmsg">
                  <assign to="/ProcessData/PrimaryDocument" from="if(boolean(//Result/Client[1]/GET_DOCS_TYPE/text() = &apos;FSA_PULL&apos;),//*[ name() =  concat(&apos;FSA_Document&apos;,//currentdoc/text())]/@SCIObjectID,//*[ name() =  concat(&apos;SFTPPrimDoc&apos;,//currentdoc/text())]/@SCIObjectID)"></assign>
                  <assign to="assignedFilename" from="if(boolean(//Result/Client[1]/GET_DOCS_TYPE/text() = &apos;FSA_PULL&apos;),string(//*[ name() =  concat(&apos;FSA_Document&apos;,//currentdoc/text())]/@filename),string(//Files/File[number(//currentdoc)]/Name/text()))"></assign>
                  <assign to="//VITAL/FLOW_ID" from="//thisProcessInstance/INVOKE_ID_LIST/text()"></assign>
                  <assign to="//VITAL/TRANS_TYPE" from="concat(//Result/Client[1]/PROCESS_TYPE/text(),if(boolean(string(//Result/Client[1]/BUSINESS_TYPE/text()) = &apos;&apos;),&apos;&apos;,concat(&apos;_&apos;,//Result/Client[1]/BUSINESS_TYPE/text())))"></assign>
                  <assign to="//VITAL/TRANSACTIONS" from="if(boolean(string(//Result/Client[1]/POST_TRANSLATION_VITAL/text()) = &apos;Y&apos; and currentdoc = 1),concat(&apos;&apos;,&apos;&apos;),&apos;&apos;)" append="true"></assign>
                </output>
                <input message="inmsg">
                  <assign to="." from="*"></assign>
                </input>
              </operation>

              <choice name="Choice Start">
                <select>
                  <case ref="PreArchive?" activity="PreArchive"/>
                </select>

                <sequence name="PreArchive">
                  <operation name="AssignService">
                    <participant name="AssignService"/>
                    <output message="outmsg">
                      <assign to="PreArchiveFlag">1</assign>
                      <assign to="//Result/Client/PRE_ARCHIVE" from="if(boolean(//Result/Client[1]/PRE_ARCHIVE/text() = &apos;Y&apos;),concat(//Settings/Values/DEF_POST_ARCHIVE/text(),&apos;\&apos;,//Result/Client[1]/COMM_METHOD/text(),&apos;\&apos;,//ClientArchiveName/text()),//Result/Client[1]/PRE_ARCHIVE/text())"></assign>
                    </output>
                    <input message="inmsg">
                      <assign to="." from="*"></assign>
                    </input>
                  </operation>

                  <operation name="Invoke Business Process Service">
                    <participant name="InvokeBusinessProcessService"/>
                    <output message="InvokeBusinessProcessServiceTypeInputMessage">
                      <assign to="." from="*"></assign>
                      <assign to="INVOKE_MODE">INLINE</assign>
                      <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
                      <assign to="WFD_NAME">FA_CLIENTS_ARCHIVE</assign>
                    </output>
                    <input message="inmsg">
                      <assign to="." from="*"></assign>
                    </input>
                  </operation>

                  <assign name="Assign" to="//PreArchiveFlag">0</assign>
                </sequence>
              </choice>
              <choice name="Choice Start">
                <select>
                  <case ref="Prep?" activity="PrepSource"/>
                </select>

                <sequence name="PrepSource">
                  <operation name="Invoke Business Process Service">
                    <participant name="InlineInvokeBusinessProcessService"/>
                    <output message="InvokeBusinessProcessServiceTypeInputMessage">
                      <assign to="." from="*"></assign>
                      <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
                      <assign to="WFD_NAME">FA_CLIENTS_PREP_SOURCE</assign>
                    </output>
                    <input message="inmsg">
                      <assign to="." from="*"></assign>
                    </input>
                  </operation>

                </sequence>
              </choice>
              <operation name="AssignService">
                <participant name="AssignService"/>
                <output message="outmsg">
                  <assign to="//VITAL/TRANSACTIONS/DOC_PATH" from="concat(if (boolean(//Result/Client[1]/PRE_ARCHIVE/text() = &apos;N&apos; or //Result/Client[1]/PRE_ARCHIVE/text() = &apos;&apos;),//Result/Client[1]/POST_ARCHIVE/text(),//Result/Client[1]/PRE_ARCHIVE/text()),&apos;\&apos;,substring(//time/text(),1,4),&apos;\&apos;,substring(//time/text(),5,2),&apos;\&apos;,substring(//time/text(),7,2),&apos;\&apos;,if(boolean(//tmpFileRename/text() = &apos;&apos;),//assignedFilename/text(),//tmpFileRename/text()))"></assign>
                  <assign to="//VITAL/TRANSACTIONS/FILE_NAME" from="//assignedFilename/text()"></assign>
                  <assign to="//Result/Client/NEW_FILE_FILTER" from="if(boolean(string(//Result/Client[1]/PREP_TRANSLATION_MAP/text()) = &apos;&apos; and string(//Result/Client[1]/PGP_PASSPHRASE/text()) != &apos;&apos; and string(//Result/Client[1]/PGP_PASSPHRASE/text()) != &apos;N&apos; and string(//Result/Client[1]/UNZIP_FILTER/text()) != &apos;&apos; and string(//Result/Client[1]/UNZIP_FILTER/text()) != &apos;N&apos;),string(//Result/Client[1]/UNZIP_FILTER/text()),if(boolean(string(//Result/Client[1]/PREP_TRANSLATION_MAP/text()) = &apos;&apos; and string(//Result/Client[1]/PGP_PASSPHRASE/text()) != &apos;&apos; and string(//Result/Client[1]/PGP_PASSPHRASE/text()) != &apos;N&apos; and (string(//Result/Client[1]/UNZIP_FILTER/text()) = &apos;&apos; or string(//Result/Client[1]/UNZIP_FILTER/text()) = &apos;N&apos;)),concat(string(//assignedFilename/text()),&apos;.PGPOUT&apos;),if(boolean(string(//Result/Client[1]/PREP_TRANSLATION_MAP/text()) = &apos;&apos; and (string(//Result/Client[1]/PGP_PASSPHRASE/text()) = &apos;&apos; or string(//Result/Client[1]/PGP_PASSPHRASE/text()) = &apos;N&apos;) and string(//Result/Client[1]/UNZIP_FILTER/text()) != &apos;&apos; and string(//Result/Client[1]/UNZIP_FILTER/text()) != &apos;N&apos;),string(//Result/Client[1]/UNZIP_FILTER/text()),string(//assignedFilename/text()))))"></assign>
                </output>
                <input message="inmsg">
                  <assign to="." from="*"></assign>
                </input>
              </operation>

              <choice name="Choice Start">
                <select>
                  <case ref="RemoveSpecialCharacters?" activity="RemoveSpecialCharacters"/>
                </select>

                <sequence name="RemoveSpecialCharacters">
                  <operation name="Command Line 2 Adapter">
                    <participant name="CommandLineAdapter2"/>
                    <output message="CmdLine2InputMessage">
                      <assign to="." from="*"></assign>
                      <assign to="cmdLine">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_INT_Tools\FA_FILE_REMOVE_SPECIAL_CHARACTERS.exe &quot;$0&quot; &quot;$1&quot; &quot;$2&quot; &quot;$3&quot; &quot;$4&quot; &quot;$5&quot; &quot;$6&quot; &quot;$7&quot;</assign>
                      <assign to="parm0" from="string(//Settings/Values/DATABASE_SERVER/text())"></assign>
                      <assign to="parm1" from="concat(//Result/Client[1]/PRE_ARCHIVE/text(),&apos;\&apos;,substring(//time/text(),1,4),&apos;\&apos;,substring(//time/text(),5,2),&apos;\&apos;,substring(//time/text(),7,2),&apos;\&apos;)"></assign>
                      <assign to="parm2" from="string(//Result/Client[1]/NEW_FILE_FILTER/text())"></assign>
                      <assign to="parm3" from="string(//Result/Client[1]/CLIENT_ID/text())"></assign>
                      <assign to="parm4" from="string(//Result/Client[1]/SEQ_ID/text())"></assign>
                      <assign to="parm5" from="string(//Result/Client[1]/CLIENT_NAME/text())"></assign>
                      <assign to="parm6" from="string(//thisProcessInstance/INVOKE_ID_LIST/text())"></assign>
                      <assign to="parm7" from="string(//Result/Client[1]/FILE_CLEAN_UP/text())"></assign>
                      <assign to="setSoTimeout">1200000</assign>
                      <assign to="workingDir">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_INT_Tools</assign>
                    </output>
                    <input message="inmsg">
                      <assign to="." from="*"></assign>
                    </input>
                  </operation>

                  <operation name="File System Adapter">
                    <participant name="AS3FSAdapter"/>
                    <output message="FileSystemInputMessage">
                      <assign to="Action">FS_COLLECT</assign>
                      <assign to="assignFilename">false</assign>
                      <assign to="bootstrap">false</assign>
                      <assign to="collectionFolder" from="concat(//Result/Client[1]/PRE_ARCHIVE/text(),&apos;\&apos;,substring(//time/text(),1,4),&apos;\&apos;,substring(//time/text(),5,2),&apos;\&apos;,substring(//time/text(),7,2))"></assign>
                      <assign to="collectMultiple">false</assign>
                      <assign to="collectZeroByteFiles">false</assign>
                      <assign to="deleteAfterCollect">false</assign>
                      <assign to="docStorageType">db</assign>
                      <assign to="fileModTimeThreshold">5</assign>
                      <assign to="filter" from="string(//Result/Client[1]/NEW_FILE_FILTER/text())"></assign>
                      <assign to="noFilesSetSuccess">true</assign>
                      <assign to="thresholdWait">true</assign>
                      <assign to="useSubFolders">false</assign>
                      <assign to="." from="*"></assign>
                    </output>
                    <input message="inmsg">
                      <assign to="." from="*"></assign>
                    </input>
                  </operation>

                </sequence>
              </choice>
              <choice name="Choice Start">
                <select>
                  <case ref="Translate?" activity="Translation"/>
                </select>

                <sequence name="Translation">
                  <operation name="Invoke Business Process Service">
                    <participant name="InlineInvokeBusinessProcessService"/>
                    <output message="InvokeBusinessProcessServiceTypeInputMessage">
                      <assign to="." from="*"></assign>
                      <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
                      <assign to="WFD_NAME">FA_CLIENTS_TRANS</assign>
                    </output>
                    <input message="inmsg">
                      <assign to="." from="*"></assign>
                    </input>
                  </operation>

                </sequence>
              </choice>
              <choice name="Choice Start">
                <select>
                  <case ref="PostTranslationVITAL?" negative="true" activity="NotPostTranslation"/>
                </select>

                <sequence name="NotPostTranslation">
                  <choice name="Choice Start">
                    <select>

<process name="FA_CLIENTS_TRANS">
  <rule name="OutBound?">
    <condition>//Result/Client[1]/COMM_METHOD/text() = &apos;OUTBOUND&apos;</condition>
  </rule>

  <rule name="EmptyFile?">
    <condition>(//FILELIST/SIZE[number(//currentdoc/text())]/text() &gt; 0 and //Result/Client[1]/SEND_EMPTY_FILES/text() = &apos;N&apos;) or string(//Result/Client[1]/SEND_EMPTY_FILES/text()) != &apos;N&apos;</condition>
  </rule>

  <sequence name="Start_Trans">
    <assign name="Assign" to="PlacementDate" from="substring(substring(//assignedFilename/text(), string-length(//assignedFilename/text()) - 10),1, 6)"></assign>
    <choice name="Choice Start">
      <select>
        <case ref="OutBound?" activity="OutBound"/>
        <case ref="OutBound?" negative="true" activity="Inbound"/>
      </select>

      <sequence name="OutBound">
        <operation name="Release Service">
          <participant name="ReleaseService"/>
          <output message="outmsg">
            <assign to="TARGET">assignedFilename</assign>
          </output>
          <input message="inmsg">
          </input>
        </operation>

        <operation name="Translation">
          <participant name="Translation"/>
          <output message="TranslationTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="map_name" from="//Result/Client[1]/TRANSLATION_MAP/text()"></assign>
            <assign to="output_to_process_data">NO</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
            <assign to="." from="Status_Rpt(&apos;StatusReport&apos;)"></assign>
          </input>
        </operation>

        <operation name="AssignService">
          <participant name="AssignService"/>
          <output message="outmsg">
            <assign to="//VITAL/TRANSACTIONS/FILE_NAME" from="//assignedFilename/text()"></assign>
            <assign to="//VITAL/TRANSACTIONS/DOC_PATH" from="if(boolean(//Result/Client[1]/POST_ARCHIVE/text() != &apos;N&apos;),concat(//Settings/Values/DEF_POST_ARCHIVE/text(),&apos;\&apos;,//Result/Client[1]/COMM_METHOD/text(),&apos;\&apos;,//ClientArchiveName/text(),&apos;\&apos;,substring(//time/text(),1,4),&apos;\&apos;,substring(//time/text(),5,2),&apos;\&apos;,substring(//time/text(),7,2),&apos;\&apos;,//assignedFilename/text()),&apos;&apos;) "></assign>
            <assign to="//FILELIST/SIZE" from="count(//VITAL/TRANSACTIONS/TRANSACTION)" append="true"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="Release Service">
          <participant name="ReleaseService"/>
          <output message="outmsg">
            <assign to="TARGET">/ProcessData/*[name()= &apos;DocumentName&apos; or name()= &apos;BodyName&apos; or name()= &apos;DocumentInitialId&apos;]</assign>
          </output>
          <input message="inmsg">
          </input>
        </operation>

        <choice name="Choice Start">
          <select>
            <case ref="EmptyFile?" activity="RenameFile"/>
          </select>

          <sequence name="RenameFile">
            <operation name="Get Document Information Service">
              <participant name="GetDocumentInfoService"/>
              <output message="GetDocumentInfoServiceTypeInputMessage">
                <assign to="BodyName" from="//assignedFilename/text()"></assign>
                <assign to="DOCUMENT_ID" from="//PrimaryDocument/@SCIObjectID"></assign>
                <assign to="updateMetaDataOnly">true</assign>
                <assign to="DocumentName" from="//assignedFilename/text()"></assign>
                <assign to="." from="*"></assign>
              </output>
              <input message="inmsg">
                <assign to="." from="*"></assign>
              </input>
            </operation>

          </sequence>
        </choice>
      </sequence>
      <sequence name="Inbound">
        <operation name="Translation">
          <participant name="Translation"/>
          <output message="TranslationTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="map_name" from="//Result/Client[1]/TRANSLATION_MAP/text()"></assign>
            <assign to="output_to_process_data">NO</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
            <assign to="." from="Status_Rpt(&apos;StatusReport&apos;)"></assign>
          </input>
        </operation>

        <operation name="Release Service">
          <participant name="ReleaseService"/>
          <output message="outmsg">
            <assign to="TARGET">/ProcessData/*[name()= &apos;DocumentName&apos; or name()= &apos;BodyName&apos; or name()= &apos;DocumentInitialId&apos;]</assign>
          </output>
          <input message="inmsg">
          </input>
        </operation>

      </sequence>
    </choice>
  </sequence>
</process>

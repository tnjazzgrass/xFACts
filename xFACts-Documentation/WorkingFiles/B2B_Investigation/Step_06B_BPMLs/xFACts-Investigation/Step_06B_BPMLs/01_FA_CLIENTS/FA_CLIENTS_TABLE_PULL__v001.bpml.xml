<process name="FA_CLIENTS_TABLE_PULL">
  <sequence name="TablePull">
    <operation name="Lightweight JDBC Adapter">
      <participant name="LightweightJDBCAdapterQuery"/>
      <output message="LightweightJDBCAdapterTypeInputMessage">
        <assign to="param1" from="//thisProcessInstance/INVOKE_ID_LIST/text()"></assign>
        <assign to="paramtype1">Integer</assign>
        <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
        <assign to="query_type">SELECT</assign>
        <assign to="result_name">OutPut</assign>
        <assign to="row_name">File</assign>
        <assign to="sql">select XML_FILE as xmlFile from etl.tbl_B2B_CLIENTS_MERGED_FILES where run_id = ?</assign>
        <assign to="." from="*"></assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <operation name="Release Service">
      <participant name="ReleaseService"/>
      <output message="outmsg">
        <assign to="TARGET">PrimaryDocument</assign>
      </output>
      <input message="inmsg">
      </input>
    </operation>

    <assign name="Assign" to="PrimaryDocument" from="//doc-1/@SCIObjectID"></assign>
    <operation name="Release Service">
      <participant name="ReleaseService"/>
      <output message="outmsg">
        <assign to="TARGET">doc-1</assign>
      </output>
      <input message="inmsg">
      </input>
    </operation>

    <operation name="Release Service">
      <participant name="ReleaseService"/>
      <output message="outmsg">
        <assign to="TARGET">DocumentName</assign>
      </output>
      <input message="inmsg">
      </input>
    </operation>

    <operation name="Release Service">
      <participant name="ReleaseService"/>
      <output message="outmsg">
        <assign to="TARGET">BodyName</assign>
      </output>
      <input message="inmsg">
      </input>
    </operation>

    <operation name="Release Service">
      <participant name="ReleaseService"/>
      <output message="outmsg">
        <assign to="TARGET">DocumentInitialId</assign>
      </output>
      <input message="inmsg">
      </input>
    </operation>

    <operation name="Get Document Information Service">
      <participant name="GetDocumentInfoService"/>
      <output message="GetDocumentInfoServiceTypeInputMessage">
        <assign to="BodyName" from="concat(translate(//Result/Client[1]/CLIENT_NAME/text(), &apos; &apos;, &apos;_&apos;),&apos;.DM.&apos;,//time/text(),&apos;_&apos;,//thisProcessInstance/INVOKE_ID_LIST/text(),if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;),&apos;.NB&apos;,if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;TRANSACTION&apos;),&apos;.PAY&apos;,&apos;.&apos;)),&apos;.txt&apos;)"></assign>
        <assign to="DOCUMENT_ID" from="//PrimaryDocument/@SCIObjectID"></assign>
        <assign to="updateMetaDataOnly">true</assign>
        <assign to="DocumentName" from="concat(translate(//Result/Client[1]/CLIENT_NAME/text(), &apos; &apos;, &apos;_&apos;),&apos;.DM.&apos;,//time/text(),&apos;_&apos;,//thisProcessInstance/INVOKE_ID_LIST/text(),if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos;),&apos;.NB&apos;,if(boolean(//Result/Client[1]/PROCESS_TYPE/text() = &apos;TRANSACTION&apos;),&apos;.PAY&apos;,&apos;.&apos;)),&apos;.txt&apos;)"></assign>
        <assign to="." from="*"></assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

  </sequence>
</process>

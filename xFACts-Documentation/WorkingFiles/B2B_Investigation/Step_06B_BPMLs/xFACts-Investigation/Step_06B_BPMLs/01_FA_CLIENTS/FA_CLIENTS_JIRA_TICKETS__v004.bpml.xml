<process name="FA_CLIENTS_JIRA_TICKETS">
  <rule name="TicketsCreated?">
    <condition>count(//EmailInfo/Values) &gt; 0</condition>
  </rule>

  <sequence name="JIRATickets">
    <operation name="Lightweight JDBC Adapter">
      <participant name="AS2LightweightJDBCAdapter"/>
      <output message="LightweightJDBCAdapterTypeInputMessage">
        <assign to="." from="*"></assign>
        <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
        <assign to="query_type">SELECT</assign>
        <assign to="result_name">Settings</assign>
        <assign to="row_name">Values</assign>
        <assign to="sql">EXEC faint.USP_B2B_CLIENTS_GET_SETTINGS</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
        <assign to="." from="DocToDOM(PrimaryDocument)"></assign>
      </input>
    </operation>

    <assign name="Assign" to="." from="DocToDOM(PrimaryDocument)"></assign>
    <operation name="Timestamp Utility">
      <participant name="TimestampUtilService"/>
      <output message="TimestampUtilServiceTypeInputMessage">
        <assign to="." from="*"></assign>
        <assign to="action">current_time</assign>
        <assign to="format">yyyyMMdd</assign>
        <assign to="scale">day</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <operation name="Command Line 2 Adapter">
      <participant name="FA_CLA_DEFAULT"/>
      <output message="CmdLine2InputMessage">
        <assign to="." from="*"></assign>
        <assign to="cmdLine">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_JIRA_TICKETS\FA_JIRA_TICKETS_API_V2.exe $0</assign>
        <assign to="inputDelete">false</assign>
        <assign to="outputDelete">false</assign>
        <assign to="parm0" from="if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;DM-PROD-APP3&apos;,&apos;DM-TEST-APP&apos;)"></assign>
        <assign to="setSoTimeout">120000</assign>
        <assign to="workingDir">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_JIRA_TICKETS</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
        <assign to="." from="Status_Rpt(&apos;StatusReport&apos;)"></assign>
      </input>
    </operation>

    <operation name="AssignService">
      <participant name="AssignService"/>
      <output message="outmsg">
        <assign to="//Result/Client/EMAIL_XSLT">FA_JIRA_TICKETS_SUMMARY</assign>
        <assign to="//Result/Client/MAIL_TO">datahelp@frost-arnett.com</assign>
        <assign to="//Result/Client/CLIENT_NAME">JIRA Tickets</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <operation name="Release Service">
      <participant name="ReleaseService"/>
      <output message="outmsg">
        <assign to="TARGET">PrimaryDocument</assign>
      </output>
      <input message="inmsg">
      </input>
    </operation>

    <operation name="Lightweight JDBC Adapter">
      <participant name="AS2LightweightJDBCAdapter"/>
      <output message="LightweightJDBCAdapterTypeInputMessage">
        <assign to="." from="*"></assign>
        <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
        <assign to="query_type">SELECT</assign>
        <assign to="result_name">EmailInfo</assign>
        <assign to="row_name">Values</assign>
        <assign to="sql">SELECT A.CLIENT_NAME,ISNULL(TICKET_NUM,&apos;N/A&apos;) TICKET_NUM,TICKET_REASON,ISNULL(CAST(MAX(CAST(TICKET_DATE AS DATE)) AS VARCHAR(100)),&apos;N/A&apos;) TICKET_DATE, COUNT(*) ACCOUNT_NUMBER, ISNULL(TRY_CAST(SUM(BALANCE) AS MONEY),0.0) BALANCE  FROM ETL.tbl_B2B_CLIENTS_TICKETS A LEFT JOIN ETL.tbl_B2B_CLIENTS_ACCTS B ON A.ACCT_ID = B.ID   WHERE A.TICKET_DATE BETWEEN DATEADD(HOUR,-1,GETDATE()) AND GETDATE() GROUP BY A.CLIENT_NAME,TICKET_NUM,TICKET_REASON</assign>
      </output>
      <input message="inmsg">
        <assign to="." from="*"></assign>
        <assign to="." from="DocToDOM(PrimaryDocument)"></assign>
      </input>
    </operation>

    <assign name="Assign" to="." from="DocToDOM(PrimaryDocument)"></assign>
    <choice name="Choice Start">
      <select>
        <case ref="TicketsCreated?" activity="SendEmail"/>
      </select>

      <sequence name="SendEmail">
        <operation name="Invoke Business Process Service">
          <participant name="InlineInvokeBusinessProcessService"/>
          <output message="InvokeBusinessProcessServiceTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
            <assign to="WFD_NAME">FA_CLIENTS_EMAIL</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
    <onFault>
      <operation name="Invoke Business Process Service">
        <participant name="InvokeBusinessProcessService"/>
        <output message="InvokeBusinessProcessServiceTypeInputMessage">
          <assign to="." from="*"></assign>
          <assign to="INVOKE_MODE">ASYNC</assign>
          <assign to="NOTIFY_PARENT_ON_ERROR">ALL</assign>
          <assign to="WFD_NAME">EmailOnError</assign>
        </output>
        <input message="inmsg">
          <assign to="." from="*"></assign>
        </input>
      </operation>

    </onFault>
  </sequence>
</process>

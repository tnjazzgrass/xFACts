<process name = "FA_CLIENTS_COMM_CALL"> 
  <rule name="DM?">
    <condition>//Result/Client[1]/PROCESS_TYPE/text() = &apos;BDL&apos; or (((//Result/Client[1]/PROCESS_TYPE/text() = &apos;NEW_BUSINESS&apos; or //Result/Client[1]/PROCESS_TYPE/text() = &apos;PAYMENT&apos;) and count(//Files/File) != 0 ) and EmptyFile = 0 and string(//DUPLICATE_FILE/text())  = &apos;&apos;)</condition>
  </rule>

  <rule name="CommCallSQL?">
    <condition>string(//Result/Client[1]/COMM_CALL_SQL_QUERY/text()) != &apos;&apos;</condition>
  </rule>

  <rule name="CommCallCustomCLA?">
    <condition>string(//Result/Client[1]/COMM_CALL_CLA_EXE_PATH/text()) != &apos;&apos;</condition>
  </rule>

  <rule name="PreDMMerge?">
    <condition>string(//Result/Client[1]/PROCESS_TYPE/text()) = &apos;NEW_BUSINESS&apos; and string(//Result/Client[1]/PRE_DM_MERGE/text()) != &apos;&apos; and string(//Result/Client[1]/PRE_DM_MERGE/text()) != &apos;N&apos;</condition>
  </rule>

  <sequence name="CommCall">
    <choice name="Choice Start">
      <select>
        <case ref="DM?" activity="DMCall"/>
      </select>

      <sequence name="DMCall">
        <choice name="Choice Start">
          <select>
            <case ref="PreDMMerge?" activity="PreDMMerge"/>
          </select>

          <sequence name="PreDMMerge">
            <operation name="Command Line 2 Adapter">
              <participant name="CommandLineAdapter2"/>
              <output message="CmdLine2InputMessage">
                <assign to="." from="*"></assign>
                <assign to="cmdLine">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_INT_Tools\FA_PRE_DM_MERGE_CONSUMERS.exe $0 $1 $2</assign>
                <assign to="parm0" from="if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;DM-PROD-APP3&apos;,&apos;DM-TEST-APP&apos;)"></assign>
                <assign to="parm1" from="//FinalFileName/text()"></assign>
                <assign to="parm2" from="string(//Result/Client[1]/PRE_DM_MERGE/text())"></assign>
                <assign to="setSoTimeout">3600000</assign>
                <assign to="workingDir">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_INT_Tools</assign>
              </output>
              <input message="inmsg">
                <assign to="." from="*"></assign>
              </input>
            </operation>

          </sequence>
        </choice>
        <operation name="Command Line 2 Adapter">
          <participant name="FA_CLA_DM_API"/>
          <output message="CmdLine2InputMessage">
            <assign to="." from="*"></assign>
            <assign to="cmdLine">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_INT_DM_API\DM_API_SPLIT.exe $0 $1 $2 $3 $4 $5</assign>
            <assign to="inputDelete">false</assign>
            <assign to="outputDelete">false</assign>
            <assign to="parm0" from="if(boolean(//Settings/Values/DATABASE_SERVER/text() = &apos;AVG-PROD-LSNR&apos;),&apos;DM-PROD-APP3&apos;,&apos;DM-TEST-APP&apos;)"></assign>
            <assign to="parm1" from="//Settings/Values/API_PORT/text()"></assign>
            <assign to="parm2" from="//DMBatchType/text()"></assign>
            <assign to="parm3" from="//FinalFileName/text()"></assign>
            <assign to="parm4" from="if(boolean(//Result/Client[1]/AUTO_RELEASE/text() = &apos;Y&apos; or //DMBatchType/text() = &apos;PAYMENT&apos;),&apos;Yes&apos;,&apos;No&apos;)"></assign>
            <assign to="parm5" from="//Result/Client[1]/DM_BATCH_SPLIT/text()"></assign>
            <assign to="setSoTimeout">3600000</assign>
            <assign to="workingDir">\\kingkong\Data_Processing\Pervasive\Python_EXE_files\FA_INT_DM_API</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
            <assign to="." from="Status_Rpt(&apos;StatusReport&apos;)"></assign>
          </input>
        </operation>

        <operation name="Lightweight JDBC Adapter">
          <participant name="AS2LightweightJDBCAdapter"/>
          <output message="LightweightJDBCAdapterTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="param1" from="substring(substring(//StatusReport,17),1,string-length(substring(//StatusReport,17))-10)"></assign>
            <assign to="param2" from="number(//thisProcessInstance/INVOKE_ID_LIST/text())"></assign>
            <assign to="paramtype1">String</assign>
            <assign to="paramtype2">Integer</assign>
            <assign to="pool">AVG_PROD_LSNR_INTEGRATION</assign>
            <assign to="query_type">UPDATE</assign>
            <assign to="result_name">Result</assign>
            <assign to="row_name">Client</assign>
            <assign to="sql">UPDATE INTEGRATION.ETL.tbl_B2B_CLIENTS_BATCH_STATUS SET BATCH_ID = ? WHERE RUN_ID = ?</assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
    <choice name="Choice Start">
      <select>
        <case ref="CommCallCustomCLA?" activity="CommCallCustomCLA"/>
      </select>

      <sequence name="CommCallCustomCLA">
        <operation name="Command Line 2 Adapter">
          <participant name="FA_CLA_DEFAULT"/>
          <output message="CmdLine2InputMessage">
            <assign to="." from="*"></assign>
            <assign to="cmdLine" from="//Result/Client[1]/COMM_CALL_CLA_EXE_PATH/text()"></assign>
            <assign to="inputDelete">false</assign>
            <assign to="outputDelete">false</assign>
            <assign to="parm0" from="//Settings/Values/DATABASE_SERVER/text()"></assign>
            <assign to="parm1" from="concat(//Result/Client[1]/PRE_ARCHIVE/text(),&apos;\&apos;,substring(//time/text(),1,4),&apos;\&apos;,substring(//time/text(),5,2),&apos;\&apos;,substring(//time/text(),7,2),&apos;\&apos;,//assignedFilename/text())    "></assign>
            <assign to="parm2" from="//Result/Client[1]/MISC_REC1/text()"></assign>
            <assign to="parm3" from="//thisProcessInstance/INVOKE_ID_LIST/text()"></assign>
            <assign to="setSoTimeout">36000000</assign>
            <assign to="workingDir" from="//Result/Client[1]/COMM_CALL_WORKING_DIR/text()"></assign>
          </output>
          <input message="inmsg">
            <assign to="." from="*"></assign>
          </input>
        </operation>

      </sequence>
    </choice>
    <choice name="Choice Start">
      <select>
        <case ref="CommCallSQL?" activity="CommCallSQL"/>
      </select>

      <sequence name="CommCallSQL">
        <operation name="This Service">
          <participant name="This"/>
          <output message="assignRequest">
            <assign to="from" from="//Result/Client/COMM_CALL_SQL_QUERY/text()"></assign>
            <assign to="to" from="&apos;//Result/Client/COMM_CALL_SQL_QUERY&apos;"></assign>
          </output>
          <input message="assignResponse">
            <assign to="." from="*"></assign>
          </input>
        </operation>

        <operation name="Lightweight JDBC Adapter">
          <participant name="AS2LightweightJDBCAdapter"/>
          <output message="LightweightJDBCAdapterTypeInputMessage">
            <assign to="." from="*"></assign>
            <assign to="pool" from="if(boolean(//Result/Client[1]/SQL_QUERY_DATA_SOURCE/text()!= &apos;&apos;),//Result/Client[1]/SQL_QUERY_DATA_SOURCE/text(),&apos;AVG_PROD_LSNR_INTEGRATION&apos;)"></assign>
            <assign to="query_type">ACTION</assign>
            <assign to="result_name">Result</assign>
            <assign to="row_name">Client</assign>
            <assign to="sql" from="//Result/Client/COMM_CALL_SQL_QUERY/text()"></assign>
          </output>
          <input message="inmsg">
          </input>
        </operation>

      </sequence>
    </choice>
  </sequence>
</process>


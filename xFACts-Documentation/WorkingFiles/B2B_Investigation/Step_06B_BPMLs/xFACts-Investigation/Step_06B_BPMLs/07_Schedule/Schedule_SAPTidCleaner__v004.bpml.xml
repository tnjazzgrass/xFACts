<!--
 *
 * The Schedule_SAPTidCleaner business process allows deleting TID entries from SAP_TID table that older than a specified number of days.
 * The business process is intended to be started by a SI Schedule periodically.
 * 
 * Input Parameter (optional): DeleteTIDAfterDays (numeric value)
 *                             If parameter does not exist the service uses DEFAULT_DELETE_TID_AFTER_DAYS (30 days).
 *                             If parameter exists but number is negative the service uses 0 days (all entries). 
 * Output Parameter: None 
 *
-->

<process name="Schedule_SAPTidCleaner">
	<sequence name="Sequence Start">
         <operation name="CleanOldTIDEntries">
                    <participant name="SAPTidCleanerInstance"/>
                    <output message="InputMessage">
                       <assign to="." from="*"/>
                    </output>
                    <input message="inmsg">
                       <assign to="." from="*"/>
                    </input>
                </operation>
	</sequence>
</process>

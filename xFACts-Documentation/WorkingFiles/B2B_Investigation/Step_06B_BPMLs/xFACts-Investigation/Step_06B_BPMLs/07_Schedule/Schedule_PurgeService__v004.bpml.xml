<process name="Schedule_PurgeService">
  <rule name="obtainLock">
    <condition>controlLock =&apos;true&apos; </condition>
  </rule>
  <rule name="hppPurgeRunning">
	<condition>LOCK_EXIST=&apos;true&apos;</condition>
  </rule>

  <sequence>
    <operation name="IsLock">
      <participant name="SystemLockService"/>
      <output message="Xout">
	<assign to="ACTION">Check</assign>
        <assign to="LOCK_KEY">hpp.Purge</assign>
	<assign to="USER">admin</assign>
        <assign to="." from="*"></assign>
      </output>
      <input message="Xin">
        <assign to="." from="*"></assign>
      </input>
    </operation>
    <choice name="hppurgeexists">
      <select>
        <case ref="hppPurgeRunning" activity="ExternalPurgeRunning"/>
      </select>

      <sequence name="ExternalPurgeRunning">
       <assign to="Document/Status" append="true">Failed!</assign>
       <assign to="Document/Msg" append="true">Schedule purge enabled at same time as external purge</assign>
       <assign to="Document/CurrentHost" append="true">FA-INT-APPP</assign>
       <assign to="Document/CurrentPort" append="true">4000</assign>
       <assign to="Document/DetailMsg"  append="true">Please disable the scheduled purge when using external purge.</assign>
       <assign to="sandbox_smtp_host" from="sci-get-property('sandbox.cfg','SI_ADMIN_SMTP_HOST')"></assign>

               <operation name="SMTP Send">
         <participant name="SMTP_SEND_ADAPTER"/>
         <output message="SMTP_SEND_ADAPTERInputMessage">
           <assign to="xport-smtp-mailfrom">datahelp@frost-arnett.com</assign>
           <assign to="xport-smtp-mailhost" from="//sandbox_smtp_host/text()"></assign>
           <assign to="xport-smtp-mailport">25</assign>
            <assign to="xport-smtp-mailto">datahelp@frost-arnett.com</assign>
           <assign to="xport-smtp-mailsubject">Automated Event Notification - Schedule_PurgeService is enabled while External Purge is running.</assign>
           <assign to="PrimaryDocument" from="DOMToDoc(Document)/@*"></assign>
           <assign to="." from="*"></assign>
         </output>
         <input message="inmsg">
           <assign to="." from="*"></assign>
         </input>
       </operation>

      </sequence>
    </choice>
    <assign to="controlLock">false</assign>
    <operation name="SetLock">
      <participant name="SystemLockService"/>
      <output message="Xout">
        <assign to="RELEASELOCK_FROMRECOVER">true</assign>
        <assign to="LOCK_KEY">PURGE_SERVICE</assign>
        <assign to="DURATION">86400000</assign>
        <assign to="CLEAR_ON_START_UP">true</assign>
        <assign to="." from="*"></assign>
      </output>
      <input message="Xin">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <assign to="controlLock">true</assign>
    <operation name="Service">
      <participant name="PurgeService"/>
      <output message="Xout">
        <assign to="." from="*"></assign>
      </output>
      <input message="Xin">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <operation name="unLock">
      <participant name="SystemLockService"/>
      <output message="Xout">
        <assign to="ACTION">unlock</assign>
        <assign to="LOCK_KEY">PURGE_SERVICE</assign>
        <assign to="." from="*"></assign>
      </output>
      <input message="Xin">
        <assign to="." from="*"></assign>
      </input>
    </operation>

    <onFault>
      <sequence name="LockFaild">
        <choice>
          <select>
            <case ref="obtainLock" activity="proceedWithLocking"/>
            <case ref="obtainLock" negative="true" activity="stopWithoutLocking"/>
          </select>

          <sequence name="proceedWithLocking">
            <operation>
              <participant name="SystemLockService"/>
              <output message="Xout">
                <assign to="ACTION">unlock</assign>
                <assign to="LOCK_KEY">PURGE_SERVICE</assign>
                <assign to="." from="*"></assign>
              </output>
              <input message="Xin">
                <assign to="." from="*"></assign>
              </input>
            </operation>

          </sequence>
          <sequence name="stopWithoutLocking">
            <assign to="Document/Msg" append="true">Failed to obtain a lock.!</assign>
          </sequence>
        </choice>
 <assign to="Document/Status" append="true">Failed!</assign>
       <assign to="Document/Msg" append="true">Purging failed!</assign>
       <assign to="Document/CurrentHost" append="true">FA-INT-APPP</assign>
       <assign to="Document/CurrentPort" append="true">4000</assign>
       <assign to="Document/DetailMsg" from="/ProcessData/StatusRpt/text()" append="true"></assign>
       <assign to="sandbox_smtp_host" from="sci-get-property('sandbox.cfg','SI_ADMIN_SMTP_HOST')"></assign>
       <operation name="SMTP Send">
         <participant name="SMTP_SEND_ADAPTER"/>
         <output message="SMTP_SEND_ADAPTERInputMessage">
           <assign to="xport-smtp-mailfrom">datahelp@frost-arnett.com</assign>
           <assign to="xport-smtp-mailhost" from="//sandbox_smtp_host/text()"></assign>
           <assign to="xport-smtp-mailport">25</assign>
            <assign to="xport-smtp-mailto">datahelp@frost-arnett.com</assign>
           <assign to="xport-smtp-mailsubject">Automated Event Notification - Purging Failed</assign>
           <assign to="PrimaryDocument" from="DOMToDoc(Document)/@*"></assign>
           <assign to="." from="*"></assign>
         </output>
         <input message="inmsg">
           <assign to="." from="*"></assign>
         </input>
       </operation>
      </sequence>
    </onFault>
  </sequence>
</process>


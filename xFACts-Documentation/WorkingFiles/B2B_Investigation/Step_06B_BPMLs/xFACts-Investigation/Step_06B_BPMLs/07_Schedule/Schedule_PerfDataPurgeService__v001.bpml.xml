<process name="Schedule_PerfDataPurgeService">
<sequence>
<operation name="SetLock">
        <participant name="SystemLockService"/>
           <output message="Xout">
                <assign to="RELEASELOCK_FROMRECOVER">true</assign>
                <assign to="LOCK_KEY">Purge_YSTATS_DATA</assign>
                <assign to="DURATION">86400000</assign>
                <assign to="CLEAR_ON_START_UP">true</assign>
                <assign to="." from="*"/>
           </output>
           <input message="Xin">
                <assign to="." from="*"/>
           </input>
</operation>
<operation name="PerfDataPurgeServiceType">
        <participant name="PerfDataPurgeService"/>
           <output message="PerfDataOut">
              <assign to="Purge_Offset">600</assign>
              <assign to="." from="*"/>
           </output>
           <input message="Xin">
              <assign to="." from="*"/>
           </input>
</operation>
<operation name="LightweightJDBCEngineService">
        <participant name="LightweightJDBCEngineService"/>
           <output message="DeleteRowMessage">
                <assign to="pool">mssqlPool</assign>
                <assign to="row_name">row</assign>
                <assign to="query_type">ACTION</assign>
                <assign to="result_name">result</assign>
                <assign to="." from="*"/>
           </output>
           <input message="inmsg">
                <assign to="." from="*"/>
           </input>
</operation>
<operation name="unLock">
        <participant name="SystemLockService"/>
           <output message="Xout">
                <assign to="ACTION">unlock</assign>
                <assign to="LOCK_KEY">Purge_YSTATS_DATA</assign>
                <assign to="." from="*"/>
           </output>
           <input message="Xin">
                <assign to="." from="*"/>
           </input>
</operation>
<onFault>
<operation>
        <participant name="SystemLockService"/>
           <output message="Xout">
                <assign to="ACTION">unlock</assign>
                <assign to="LOCK_KEY">Purge_YSTATS_DATA</assign>
                <assign to="." from="*"/>
           </output>
           <input message="Xin">
                <assign to="." from="*"/>
           </input>
</operation>
</onFault>
</sequence>
</process>
    